#!@KSH@

#
# Stage-one Wayland backend launcher for NsCDE using labwc.
#

if [ -z "$HOME" ]; then
   echo "Error: HOME not set." >&2
   exit 2
fi

export NSCDE_VERSION="@VERSION@"
export NSCDE_BACKEND=labwc
export NSCDE_OS=$(uname -s)
export NSCDE_ROOT=@prefix@
export NSCDE_DATADIR=@NSCDE_DATADIR@
export NSCDE_LIBDIR=@NSCDE_LIBDIR@
export NSCDE_TOOLSDIR=@NSCDE_TOOLSDIR@
export FVWM_DATADIR="@FVWM_DATADIR@"
export FVWM_USERDIR="${HOME}/.NsCDE"

_nscde_saved_theme_name_set=${NSCDE_LABWC_THEME_NAME+1}
_nscde_saved_theme_name=${NSCDE_LABWC_THEME_NAME:-}
_nscde_saved_workspaces_set=${NSCDE_LABWC_WORKSPACES+1}
_nscde_saved_workspaces=${NSCDE_LABWC_WORKSPACES:-}
_nscde_saved_current_workspace_set=${NSCDE_LABWC_CURRENT_WORKSPACE+1}
_nscde_saved_current_workspace=${NSCDE_LABWC_CURRENT_WORKSPACE:-}
_nscde_saved_autostart_terminal_set=${NSCDE_LABWC_AUTOSTART_TERMINAL+1}
_nscde_saved_autostart_terminal=${NSCDE_LABWC_AUTOSTART_TERMINAL:-}
_nscde_saved_terminal_set=${NSCDE_LABWC_TERMINAL+1}
_nscde_saved_terminal=${NSCDE_LABWC_TERMINAL:-}

if [ -n "${NSCDE_STATIC_SESSION_ENV_FILE:-}" ] && [ -r "$NSCDE_STATIC_SESSION_ENV_FILE" ]; then
   set -a
   . "$NSCDE_STATIC_SESSION_ENV_FILE"
   set +a
fi

if [ -n "${_nscde_saved_theme_name_set:-}" ]; then
   export NSCDE_LABWC_THEME_NAME="$_nscde_saved_theme_name"
fi
if [ -n "${_nscde_saved_workspaces_set:-}" ]; then
   export NSCDE_LABWC_WORKSPACES="$_nscde_saved_workspaces"
fi
if [ -n "${_nscde_saved_current_workspace_set:-}" ]; then
   export NSCDE_LABWC_CURRENT_WORKSPACE="$_nscde_saved_current_workspace"
fi
if [ -n "${_nscde_saved_autostart_terminal_set:-}" ]; then
   export NSCDE_LABWC_AUTOSTART_TERMINAL="$_nscde_saved_autostart_terminal"
fi
if [ -n "${_nscde_saved_terminal_set:-}" ]; then
   export NSCDE_LABWC_TERMINAL="$_nscde_saved_terminal"
fi

# Set labwc-specific defaults before library init
export NSCDE_LABWC_CONFIG_DIR="${NSCDE_LABWC_CONFIG_DIR:-}"
export NSCDE_LABWC_THEME_NAME="${NSCDE_LABWC_THEME_NAME:-NsCDE-Stage1}"
export NSCDE_LABWC_WORKSPACES="${NSCDE_LABWC_WORKSPACES:-One,Two,Three,Four}"
export NSCDE_LABWC_CURRENT_WORKSPACE="${NSCDE_LABWC_CURRENT_WORKSPACE:-One}"
export NSCDE_LABWC_AUTOSTART_TERMINAL="${NSCDE_LABWC_AUTOSTART_TERMINAL:-1}"
export NSCDE_LABWC_PREPARE_ONLY="${NSCDE_LABWC_PREPARE_ONLY:-0}"
export NSCDE_LABWC_SKIP_PREPARE="${NSCDE_LABWC_SKIP_PREPARE:-0}"
export NSCDE_LABWC_STARTUP_LOG="${NSCDE_LABWC_STARTUP_LOG:-}"

# Palette selection for theme generation
# If NSCDE_PALETTE_FILE is not set, default to Charcoal palette
if [ -z "$NSCDE_PALETTE_FILE" ]; then
   _default_palette="@NSCDE_DATADIR@/palettes/Charcoal.dp"
   if [ -r "$_default_palette" ]; then
      export NSCDE_PALETTE_FILE="$_default_palette"
   fi
fi

# Source the shared backend library
. "@NSCDE_TOOLSDIR@/nscde_backend.shlib"

# Initialize backend environment (sets XDG paths, state paths, workspace vars)
nscde_backend_init || exit 2

# Apply labwc-specific defaults that depend on XDG paths
if [ -z "$NSCDE_LABWC_CONFIG_DIR" ]; then
   NSCDE_LABWC_CONFIG_DIR="${NSCDE_XDG_CONFIG_HOME}/labwc-nscde"
   export NSCDE_LABWC_CONFIG_DIR
fi

mkdir -p "$FVWM_USERDIR/tmp" "$NSCDE_LABWC_CONFIG_DIR"
mkdir -p "$NSCDE_THEMES_DIR"

_keybind_xml=""

# Ensure NsCDE bin dir is in PATH
nscde_backend_prepare_path

# Find the labwc binary via the backend adapter
nscde_backend_find_binary || exit 3

find_terminal()
{
   if [ -n "$NSCDE_LABWC_TERMINAL" ]; then
      echo "$NSCDE_LABWC_TERMINAL"
      return
   fi

   for term in foot weston-terminal xterm alacritty kitty; do
      if command -v "$term" >/dev/null 2>&1; then
         echo "$term"
         return
      fi
   done

   echo "xterm"
}

_labwc_terminal=$(find_terminal)

startup_log()
{
   [ -n "$NSCDE_LABWC_STARTUP_LOG" ] || return 0
   mkdir -p "$(dirname "$NSCDE_LABWC_STARTUP_LOG")" 2>/dev/null || return 0
   printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S.%3N' 2>/dev/null)" "$*" >> "$NSCDE_LABWC_STARTUP_LOG"
}

publish_session_files_fallback()
{
   startup_log "session-files:fallback:start"
   cat > "$NSCDE_LABWC_CONFIG_DIR/autostart" <<EOF
#!/bin/sh
export NSCDE_BACKEND=labwc
export NSCDE_ROOT="$NSCDE_ROOT"
export NSCDE_TOOLSDIR="$NSCDE_TOOLSDIR"
export NSCDE_DATADIR="$NSCDE_DATADIR"
export FVWM_USERDIR="$FVWM_USERDIR"
export NSCDE_LABWC_THEME_NAME="$NSCDE_THEME_NAME"
export NSCDE_LABWC_WORKSPACES="$NSCDE_WORKSPACES"
export NSCDE_LABWC_CURRENT_WORKSPACE="$NSCDE_CURRENT_WORKSPACE"
export NSCDE_LABWC_AUTOSTART_TERMINAL="$NSCDE_LABWC_AUTOSTART_TERMINAL"
export NSCDE_LABWC_TERMINAL="$_labwc_terminal"
export NSCDE_STATE_DIR="$NSCDE_STATE_DIR"
export NSCDE_COMMAND_FIFO="$NSCDE_COMMAND_FIFO"
export NSCDE_PALETTE_FILE="$NSCDE_PALETTE_FILE"
export PATH="$NSCDE_ROOT/bin:\$PATH"
export XDG_CURRENT_DESKTOP=NsCDE
export XDG_SESSION_DESKTOP=NsCDE
export DESKTOP_SESSION=NsCDE
export XDG_SESSION_TYPE=wayland
export NSCDE_PANEL_LAYOUT_EXTERNAL="${NSCDE_PANEL_LAYOUT_EXTERNAL:-0}"
export NSCDE_RUNTIME_BIN="${NSCDE_RUNTIME_BIN:-nscde-runtime}"
export NSCDE_STATIC_PANEL_LAYOUT_FILE="${NSCDE_STATIC_PANEL_LAYOUT_FILE:-}"
export NSCDE_STATIC_SESSION_ENV_FILE="${NSCDE_STATIC_SESSION_ENV_FILE:-}"
"$NSCDE_RUNTIME_BIN" daemon &
"$NSCDE_TOOLSDIR/nscde_labwc_pagerd" &
"$NSCDE_TOOLSDIR/nscde_labwc_toplevel" &
"$NSCDE_TOOLSDIR/nscde_labwc_taskd" &
"$NSCDE_TOOLSDIR/nscde_labwc_bg" &
"$NSCDE_TOOLSDIR/nscde_labwc_paneld" &
if [ "$NSCDE_LABWC_AUTOSTART_TERMINAL" = "1" ]; then
"$_labwc_terminal" &
fi
EOF
   chmod +x "$NSCDE_LABWC_CONFIG_DIR/autostart"

   cat > "$NSCDE_LABWC_CONFIG_DIR/environment" <<EOF
NSCDE_BACKEND=labwc
NSCDE_ROOT=@prefix@
NSCDE_TOOLSDIR=@NSCDE_TOOLSDIR@
NSCDE_DATADIR=@NSCDE_DATADIR@
FVWM_USERDIR=${HOME}/.NsCDE
NSCDE_PALETTE_FILE=${NSCDE_PALETTE_FILE:-}
NSCDE_LABWC_THEME_NAME=$NSCDE_THEME_NAME
NSCDE_LABWC_WORKSPACES=$NSCDE_WORKSPACES
NSCDE_LABWC_CURRENT_WORKSPACE=$NSCDE_CURRENT_WORKSPACE
NSCDE_LABWC_AUTOSTART_TERMINAL=${NSCDE_LABWC_AUTOSTART_TERMINAL:-1}
NSCDE_LABWC_TERMINAL=$_labwc_terminal
NSCDE_STATE_DIR=${NSCDE_STATE_DIR}
NSCDE_COMMAND_FIFO=${NSCDE_COMMAND_FIFO}
NSCDE_PANEL_LAYOUT_EXTERNAL=${NSCDE_PANEL_LAYOUT_EXTERNAL:-0}
NSCDE_RUNTIME_BIN=${NSCDE_RUNTIME_BIN:-nscde-runtime}
NSCDE_STATIC_PANEL_LAYOUT_FILE=${NSCDE_STATIC_PANEL_LAYOUT_FILE:-}
NSCDE_STATIC_SESSION_ENV_FILE=${NSCDE_STATIC_SESSION_ENV_FILE:-}
XDG_CURRENT_DESKTOP=NsCDE
XDG_SESSION_DESKTOP=NsCDE
DESKTOP_SESSION=NsCDE
XDG_SESSION_TYPE=wayland
XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-${HOME}/.config}
XDG_CACHE_HOME=${XDG_CACHE_HOME:-${HOME}/.cache}
XDG_DATA_HOME=${XDG_DATA_HOME:-${HOME}/.local/share}
EOF

   cat > "$NSCDE_LABWC_CONFIG_DIR/shutdown" <<EOF
#!/bin/sh
exit 0
EOF
   chmod +x "$NSCDE_LABWC_CONFIG_DIR/shutdown"
   startup_log "session-files:fallback:done"
}

publish_session_files()
{
   startup_log "session-files:start"
   if command -v "$NSCDE_RUNTIME_BIN" >/dev/null 2>&1; then
      if "$NSCDE_RUNTIME_BIN" labwc-session publish "$NSCDE_LABWC_CONFIG_DIR"; then
         chmod +x "$NSCDE_LABWC_CONFIG_DIR/autostart" "$NSCDE_LABWC_CONFIG_DIR/shutdown"
         startup_log "session-files:runtime:done"
         return 0
      fi
      startup_log "session-files:runtime:failed"
   fi

   publish_session_files_fallback
}

publish_menu_xml()
{
   startup_log "menugen:start"
   if command -v "$NSCDE_RUNTIME_BIN" >/dev/null 2>&1; then
      if "$NSCDE_RUNTIME_BIN" labwc-menu publish "$NSCDE_LABWC_CONFIG_DIR"; then
         startup_log "menugen:runtime:done"
         return 0
      fi
      startup_log "menugen:runtime:failed"
   fi

   if [ -x "$NSCDE_TOOLSDIR/nscde_labwc_menugen" ]; then
      "$NSCDE_TOOLSDIR/nscde_labwc_menugen" > "$NSCDE_LABWC_CONFIG_DIR/menu.xml"
      startup_log "menugen:shim:done"
      return 0
   fi

   echo "nscde_labwc: unable to generate menu.xml" >&2
   startup_log "menugen:missing"
   return 1
}

publish_runtime_contracts()
{
   export NSCDE_PANEL_LAYOUT_EXTERNAL="${NSCDE_PANEL_LAYOUT_EXTERNAL:-0}"
   export NSCDE_RUNTIME_BIN="${NSCDE_RUNTIME_BIN:-nscde-runtime}"

   if [ -n "${NSCDE_STATIC_PANEL_LAYOUT_FILE:-}" ] && [ -f "$NSCDE_STATIC_PANEL_LAYOUT_FILE" ]; then
      if command -v "$NSCDE_RUNTIME_BIN" >/dev/null 2>&1; then
         startup_log "panel-layout-runtime:start"
         nscde_state_ensure_dir
         if "$NSCDE_RUNTIME_BIN" panel-layout publish "$NSCDE_STATIC_PANEL_LAYOUT_FILE" > "${NSCDE_PANEL_LAYOUT_FILE}.tmp"; then
            mv "${NSCDE_PANEL_LAYOUT_FILE}.tmp" "$NSCDE_PANEL_LAYOUT_FILE"
            export NSCDE_PANEL_LAYOUT_EXTERNAL=1
            startup_log "panel-layout-runtime:done"
            return 0
         fi
         rm -f "${NSCDE_PANEL_LAYOUT_FILE}.tmp"
         startup_log "panel-layout-runtime:failed"
      fi
   fi
}

prepare_workspace_xml_fallback()
{
   _labwc_workspace_names_xml=""
   _labwc_workspace_count=0
   _labwc_workspace_index=1

   while IFS= read -r _labwc_workspace_name
   do
      _labwc_workspace_names_xml="${_labwc_workspace_names_xml}      <name>${_labwc_workspace_name}</name>
"
      _labwc_workspace_count=$_labwc_workspace_index
      _labwc_workspace_index=$((_labwc_workspace_index + 1))
   done <<EOF
$(nscde_workspace_list)
EOF

   if [ "$_labwc_workspace_count" -eq 0 ]; then
      _labwc_workspace_names_xml="      <name>One</name>
      <name>Two</name>
      <name>Three</name>
      <name>Four</name>
"
      _labwc_workspace_count=4
   fi
}

publish_rc_xml_fallback()
{
   prepare_workspace_xml_fallback

   cat > "$NSCDE_LABWC_CONFIG_DIR/rc.xml" <<EOF
<?xml version="1.0"?>
<labwc_config>
  <core>
    <decoration>server</decoration>
    <gap>0</gap>
  </core>
  <focus>
    <followMouse>$_labwc_follow_mouse</followMouse>
    <raiseOnFocus>$_labwc_raise_on_focus</raiseOnFocus>
  </focus>
  <theme>
    <name>$NSCDE_THEME_NAME</name>
    <cornerRadius>0</cornerRadius>
    <titlebar>
      <layout>menu:iconify,max</layout>
    </titlebar>
    <font place="ActiveWindow">
      <name>$_labwc_title_font_name</name>
      <size>$_labwc_title_font_size</size>
      <slant>$_labwc_title_font_slant</slant>
      <weight>$_labwc_title_font_weight</weight>
    </font>
    <font place="InactiveWindow">
      <name>$_labwc_title_font_name</name>
      <size>$_labwc_title_font_size</size>
      <slant>$_labwc_title_font_slant</slant>
      <weight>$_labwc_title_font_weight</weight>
    </font>
  </theme>
  <desktops>
    <number>$_labwc_workspace_count</number>
    <names>
$_labwc_workspace_names_xml    </names>
  </desktops>
$_keybind_xml
  <mouse>
    <default />
    <doubleClickTime>500</doubleClickTime>
    <context name="Root">
      <mousebind button="Left" action="Press">
        <action name="ShowMenu" menu="root-menu" />
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="root-menu" />
      </mousebind>
      <mousebind direction="Up" action="Scroll">
        <action name="GoToDesktop" to="left" wrap="yes" />
      </mousebind>
      <mousebind direction="Down" action="Scroll">
        <action name="GoToDesktop" to="right" wrap="yes" />
      </mousebind>
    </context>
    <context name="TitleBar">
      <mousebind button="Left" action="Press">
        <action name="Focus" />
        <action name="Raise" />
      </mousebind>
      <mousebind button="Right" action="Click">
        <action name="Focus" />
        <action name="Raise" />
        <action name="ShowMenu" menu="client-menu" />
      </mousebind>
      <mousebind direction="Up" action="Scroll">
        <action name="Unshade" />
        <action name="Focus" />
      </mousebind>
      <mousebind direction="Down" action="Scroll">
        <action name="Shade" />
      </mousebind>
    </context>
    <context name="Title">
      <mousebind button="Left" action="Drag">
        <action name="Move" />
      </mousebind>
      <mousebind button="Left" action="DoubleClick">
        <action name="ToggleMaximize" />
      </mousebind>
      <mousebind button="Right" action="Click">
        <action name="ShowMenu" menu="client-menu" />
      </mousebind>
    </context>
  </mouse>
</labwc_config>
EOF
}

publish_rc_xml()
{
   startup_log "rc.xml:start"
   if command -v "$NSCDE_RUNTIME_BIN" >/dev/null 2>&1; then
      if "$NSCDE_RUNTIME_BIN" labwc-rc publish "$NSCDE_LABWC_CONFIG_DIR"; then
         startup_log "rc.xml:runtime:done"
         return 0
      fi
      startup_log "rc.xml:runtime:failed"
   fi

   publish_rc_xml_fallback
   startup_log "rc.xml:fallback:done"
}

resolve_title_font()
{
   typeset _font_spec _font_body _font_name _font_size

   _labwc_title_font_name="Sans"
   _labwc_title_font_size="10"
   _labwc_title_font_weight="bold"
   _labwc_title_font_slant="normal"

   if [ ! -r "$NSCDE_TOOLSDIR/getfont" ]; then
      return
   fi

   _font_spec=$(ksh "$NSCDE_TOOLSDIR/getfont" -v -t bold -s large 2>/dev/null)
   case "$_font_spec" in
      xft:*)
         _font_body=${_font_spec#xft:}
         _font_size=$(printf '%s\n' "$_font_body" |
            sed -n 's/.*:size=\([0-9][0-9.]*\).*/\1/p')
         _font_name=$(printf '%s\n' "$_font_body" | awk -F: '
            BEGIN {
               split("thin ultralight light semilight book normal medium semibold bold ultrabold heavy ultraheavy italic oblique roman regular", stop_words, " ");
               for (i in stop_words) {
                  stop[tolower(stop_words[i])] = 1;
               }
            }
            {
               name = $1;
               for (i = 2; i <= NF; i++) {
                  lower = tolower($i);
                  if (lower ~ /^size=/ || lower in stop) {
                     break;
                  }
                  name = name ":" $i;
               }
               print name;
            }')

         if [ -n "$_font_name" ]; then
            _labwc_title_font_name="$_font_name"
         fi
         if [ -n "$_font_size" ]; then
            _labwc_title_font_size="$_font_size"
         fi
         if printf '%s\n' "$_font_body" | grep -qi ':oblique'; then
            _labwc_title_font_slant="oblique"
         elif printf '%s\n' "$_font_body" | grep -qi ':italic'; then
            _labwc_title_font_slant="italic"
         fi
         ;;
   esac
}

prepare_runtime()
{
   startup_log "prepare:start"
   publish_runtime_contracts

   startup_log "keybindgen:start"
   if command -v "$NSCDE_RUNTIME_BIN" >/dev/null 2>&1; then
      if _keybind_xml=$("$NSCDE_RUNTIME_BIN" labwc-keybinds publish 2>/dev/null); then
         startup_log "keybindgen:runtime:done"
      else
         _keybind_xml=""
         startup_log "keybindgen:runtime:failed"
      fi
   elif [ -x "$NSCDE_TOOLSDIR/nscde_labwc_keybindgen" ]; then
      _keybind_xml=$("$NSCDE_TOOLSDIR/nscde_labwc_keybindgen" 2>/dev/null) || true
      startup_log "keybindgen:shim:done"
   fi
   _labwc_keybind_xml_file="${NSCDE_STATE_DIR}/labwc-keybinds.xml"
   if [ -n "$_keybind_xml" ]; then
      printf '%s\n' "$_keybind_xml" > "$_labwc_keybind_xml_file"
      export NSCDE_LABWC_KEYBIND_XML_FILE="$_labwc_keybind_xml_file"
   else
      rm -f "$_labwc_keybind_xml_file"
      export NSCDE_LABWC_KEYBIND_XML_FILE=""
   fi
   startup_log "keybindgen:done"

   startup_log "theme:start"
   if [ -x "$NSCDE_TOOLSDIR/nscde_labwc_theme" ]; then
      "$NSCDE_TOOLSDIR/nscde_labwc_theme" >/dev/null
   fi
   startup_log "theme:done"

   # Source the style state library for window behavior settings
   . "@NSCDE_TOOLSDIR@/nscde_style_state.shlib" 2>/dev/null || true

   # Determine focus settings from normalized state
   _labwc_follow_mouse="yes"
   _labwc_raise_on_focus="no"
   if type nscde_style_get_focus_policy >/dev/null 2>&1; then
      _focus=$(nscde_style_get_focus_policy)
      case "$_focus" in
         ClickToFocus)
            _labwc_follow_mouse="no"
            _labwc_raise_on_focus="yes"
            ;;
      esac
   fi

   resolve_title_font

   export NSCDE_LABWC_FOLLOW_MOUSE="$_labwc_follow_mouse"
   export NSCDE_LABWC_RAISE_ON_FOCUS="$_labwc_raise_on_focus"
   export NSCDE_LABWC_TITLE_FONT_NAME="$_labwc_title_font_name"
   export NSCDE_LABWC_TITLE_FONT_SIZE="$_labwc_title_font_size"
   export NSCDE_LABWC_TITLE_FONT_SLANT="$_labwc_title_font_slant"
   export NSCDE_LABWC_TITLE_FONT_WEIGHT="$_labwc_title_font_weight"

   publish_rc_xml

   publish_menu_xml || exit 1

   publish_session_files
   startup_log "prepare:done"
}

if [ "$NSCDE_LABWC_SKIP_PREPARE" != "1" ]; then
   prepare_runtime
else
   startup_log "prepare:skipped"
fi

if [ "$NSCDE_LABWC_PREPARE_ONLY" = "1" ]; then
   startup_log "prepare:exit"
   exit 0
fi

startup_log "labwc:exec"
exec "$LABWC_BIN" --config-dir "$NSCDE_LABWC_CONFIG_DIR" "$@"
