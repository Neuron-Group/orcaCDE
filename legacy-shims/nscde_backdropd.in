#!@KSH@

#
# NsCDE runtime-owned backdrop daemon wrapper for the labwc backend.
#

if [ -z "${OS_PLUS_MACHINE_ARCH:-}" ]; then
    OS_PLUS_MACHINE_ARCH=$(uname -s)_$(uname -m)
fi

BIN="${NSCDE_TOOLSDIR}/${OS_PLUS_MACHINE_ARCH}/nscde_backdropd"

if [ ! -x "$BIN" ]; then
    echo "Error: nscde_backdropd binary not found at $BIN" >&2
    exit 1
fi

exec "$BIN" "$@"
