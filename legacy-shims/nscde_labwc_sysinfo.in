#!@PYTHON@

import os
import platform
import socket
import sys
from PyQt5.QtCore import Qt
from PyQt5.QtWidgets import (
    QApplication,
    QFrame,
    QHBoxLayout,
    QLabel,
    QPushButton,
    QVBoxLayout,
    QWidget,
)


PALETTE_KEYS = [
    "NSCDE_PALETTE_1",
    "NSCDE_PALETTE_2",
    "NSCDE_PALETTE_3",
    "NSCDE_PALETTE_4",
    "NSCDE_PALETTE_5",
    "NSCDE_PALETTE_6",
    "NSCDE_PALETTE_7",
    "NSCDE_PALETTE_8",
]

DEFAULT_PALETTE = [
    "#b7c1ca",
    "#101010",
    "#8a9baa",
    "#4f5964",
    "#355d84",
    "#355d84",
    "#6b7785",
    "#e7e7e7",
]


def env_path():
    cache_home = os.environ.get(
        "XDG_CACHE_HOME", os.path.join(os.path.expanduser("~"), ".cache")
    )
    return os.path.join(cache_home, "nscde-stage1", "panel.env")


def parse_env_file(path):
    data = {}
    if not os.path.exists(path):
        return data
    with open(path, "r", encoding="utf-8") as handle:
        for line in handle:
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            data[key] = value
    return data


def read_palette(state):
    palette = []
    for key in PALETTE_KEYS:
        color = state.get(key, "")
        if color and color.startswith("#") and len(color) == 7:
            palette.append(color)
        else:
            palette.append(None)
    return [p or d for p, d in zip(palette, DEFAULT_PALETTE)]


def build_stylesheet(pal):
    bg = pal[0]
    fg = pal[1]
    hi = pal[2]
    sh = pal[3]
    acc = pal[5]
    sbg = pal[6]
    sfg = pal[7]

    return """
            QWidget#NsCDESysinfo {{
                background-color: {sbg};
                color: {sfg};
            }}
            QFrame#mainFrame {{
                background-color: {sbg};
                border-top: 2px solid {hi};
                border-left: 2px solid {hi};
                border-right: 2px solid {sh};
                border-bottom: 2px solid {sh};
            }}
            QLabel {{
                color: {sfg};
                font-family: Sans;
                font-size: 10pt;
                background-color: transparent;
            }}
            QLabel#titleLabel {{
                font-size: 12pt;
                font-weight: bold;
            }}
            QLabel#infoLabel {{
                font-family: Monospace;
                font-size: 10pt;
            }}
            QPushButton {{
                color: {sfg};
                font-family: Sans;
                font-size: 10pt;
                font-weight: bold;
                min-width: 80px;
                padding: 4px 10px;
                background-color: {sbg};
                border-top: 2px solid {hi};
                border-left: 2px solid {hi};
                border-right: 2px solid {sh};
                border-bottom: 2px solid {sh};
            }}
            QPushButton:pressed {{
                background-color: {acc};
                color: #ffffff;
                border-top: 2px solid {sh};
                border-left: 2px solid {sh};
                border-right: 2px solid {hi};
                border-bottom: 2px solid {hi};
            }}
            """.format(
        bg=bg, fg=fg, hi=hi, sh=sh, acc=acc, sbg=sbg, sfg=sfg
    )


def gather_system_info():
    """Gather system information as label/value pairs."""
    info = []

    try:
        import pwd
        username = pwd.getpwuid(os.getuid()).pw_name
    except (KeyError, ImportError):
        username = os.environ.get("USER", "unknown")
    info.append(("User Name", username))

    hostname = platform.node().split(".", 1)[0]
    info.append(("Workstation Name", hostname))

    info.append(("Operating System", "{} {}".format(
        platform.system(), platform.release())))
    info.append(("Architecture", platform.machine()))
    info.append(("Processor", platform.processor() or "unknown"))

    try:
        ip_addr = socket.gethostbyname(socket.gethostname())
    except socket.gaierror:
        ip_addr = "(none)"
    info.append(("IP Address", ip_addr))

    try:
        domain = socket.getfqdn().split(".", 1)
        domain = domain[1] if len(domain) > 1 else "(none)"
    except (socket.gaierror, IndexError):
        domain = "(none)"
    info.append(("Domain", domain))

    try:
        with open("/proc/meminfo", "r") as f:
            meminfo = {}
            for line in f:
                parts = line.split(":")
                if len(parts) == 2:
                    key = parts[0].strip()
                    val = parts[1].strip().split()[0]
                    meminfo[key] = int(val)
        total_mb = meminfo.get("MemTotal", 0) // 1024
        avail_mb = meminfo.get("MemAvailable", 0) // 1024
        info.append(("Physical Memory", "{} MB".format(total_mb)))
        info.append(("Available Memory", "{} MB".format(avail_mb)))
    except (IOError, ValueError, KeyError):
        info.append(("Physical Memory", "(not available)"))

    try:
        with open("/proc/uptime", "r") as f:
            uptime_secs = float(f.read().split()[0])
        days = int(uptime_secs // 86400)
        hours = int((uptime_secs % 86400) // 3600)
        mins = int((uptime_secs % 3600) // 60)
        info.append(("Uptime", "{}d {}h {}m".format(days, hours, mins)))
    except (IOError, ValueError):
        info.append(("Uptime", "(not available)"))

    return info


class NsCDESysinfo(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("System Information")
        self.setObjectName("NsCDESysinfo")
        self.setMinimumWidth(400)

        self._build_ui()
        self._apply_stylesheet()

    def _build_ui(self):
        main_layout = QVBoxLayout(self)
        main_layout.setContentsMargins(0, 0, 0, 0)

        frame = QFrame()
        frame.setObjectName("mainFrame")
        frame_layout = QVBoxLayout(frame)
        frame_layout.setContentsMargins(8, 8, 8, 8)
        frame_layout.setSpacing(6)

        title = QLabel("System Information")
        title.setObjectName("titleLabel")
        title.setAlignment(Qt.AlignCenter)
        frame_layout.addWidget(title)

        info = gather_system_info()
        for label, value in info:
            row = QHBoxLayout()
            lbl = QLabel("<b>{}:</b>".format(label))
            lbl.setMinimumWidth(140)
            row.addWidget(lbl)
            val = QLabel(value)
            val.setObjectName("infoLabel")
            row.addWidget(val, 1)
            frame_layout.addLayout(row)

        close_row = QHBoxLayout()
        close_row.addStretch()
        close_btn = QPushButton("Close")
        close_btn.setFixedWidth(100)
        close_btn.clicked.connect(self.close)
        close_row.addWidget(close_btn)
        frame_layout.addLayout(close_row)

        main_layout.addWidget(frame)

    def _apply_stylesheet(self):
        state = parse_env_file(env_path())
        pal = read_palette(state)
        self.setStyleSheet(build_stylesheet(pal))


def main():
    app = QApplication(sys.argv)
    sysinfo = NsCDESysinfo()
    sysinfo.show()
    sys.exit(app.exec_())


if __name__ == "__main__":
    main()
