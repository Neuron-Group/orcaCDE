#!/bin/sh

#
# NsCDE layer-shell panel daemon wrapper for labwc backend.
#
# This script wraps the compiled nscde_paneld binary.
# The native layer-shell client is the sole panel implementation;
# the previous Qt fallback has been removed.
#
# This file is a part of NsCDE - Not so Common Desktop Environment
# Author: Hegel3DReloaded
# Licence: GPLv3
#

if [ -z "${OS_PLUS_MACHINE_ARCH:-}" ]; then
    OS_PLUS_MACHINE_ARCH=$(uname -s)_$(uname -m)
fi

BIN="${NSCDE_TOOLSDIR}/${OS_PLUS_MACHINE_ARCH}/nscde_paneld"

if [ ! -x "$BIN" ]; then
    echo "Error: nscde_paneld binary not found at $BIN" >&2
    exit 1
fi

exec "$BIN" "$@"
