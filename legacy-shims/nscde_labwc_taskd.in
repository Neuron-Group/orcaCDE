#!/bin/sh

#
# NsCDE task list refresh shim for labwc backend.
#
# Runtime-owned task state is derived directly from runtime windows state.
# This wrapper performs a one-shot runtime query for compatibility consumers
# and exits; it no longer falls back to shell-owned task publication.
#

if [ -z "$HOME" ]; then
   echo "Error: HOME not set." >&2
   exit 2
fi

_RUNTIME_BIN="${NSCDE_RUNTIME_BIN:-nscde-runtime}"

if ! command -v "$_RUNTIME_BIN" >/dev/null 2>&1; then
   echo "Error: nscde-runtime not found for taskd refresh." >&2
   exit 127
fi

if [ -n "${NSCDE_STATE_DIR:-}" ]; then
   _state_dir=$NSCDE_STATE_DIR
else
   _cache_home=${XDG_CACHE_HOME:-"$HOME/.cache"}
   _state_dir="${_cache_home}/nscde-stage1"
fi

mkdir -p "$_state_dir"

_taskd_env="${_state_dir}/taskd.env"
_taskd_tmp="${_taskd_env}.tmp"

if ! "$_RUNTIME_BIN" query taskd > "$_taskd_tmp"; then
   rm -f "$_taskd_tmp"
   echo "Error: unable to query runtime taskd state." >&2
   exit 1
fi

mv "$_taskd_tmp" "$_taskd_env"
