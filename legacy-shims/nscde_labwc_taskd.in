#!@KSH@

#
# NsCDE task list daemon for labwc backend.
#
# Compatibility wrapper for task list state publication.
# Runtime-owned task state is now derived directly from runtime windows state.
#
# This shim performs a one-shot refresh for compatibility consumers and exits.
#

if [ -z "$HOME" ]; then
   echo "Error: HOME not set." >&2
   exit 2
fi

export NSCDE_BACKEND=${NSCDE_BACKEND:-labwc}
export NSCDE_ROOT=${NSCDE_ROOT:-@prefix@}

# Source the shared backend library
. "@NSCDE_TOOLSDIR@/nscde_backend.shlib"

# Initialize backend environment
nscde_backend_init || exit 2

# Ensure state directory exists
nscde_state_ensure_dir

_RUNTIME_BIN="${NSCDE_RUNTIME_BIN:-nscde-runtime}"
_taskd_env="${NSCDE_STATE_DIR}/taskd.env"
_taskd_tmp="${_taskd_env}.tmp"

refresh_task_state() {
   if command -v "$_RUNTIME_BIN" >/dev/null 2>&1; then
      if "$_RUNTIME_BIN" query taskd > "$_taskd_tmp"; then
         mv "$_taskd_tmp" "$_taskd_env"
         return 0
      fi
      rm -f "$_taskd_tmp"
   fi

   nscde_taskd_publish
}

refresh_task_state
