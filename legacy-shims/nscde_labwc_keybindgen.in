#!/bin/sh

#
# Compatibility wrapper for runtime-owned labwc keybind publishing.
#

_runtime_bin="${NSCDE_RUNTIME_BIN:-nscde-runtime}"

if command -v "$_runtime_bin" >/dev/null 2>&1; then
   exec "$_runtime_bin" labwc-keybinds publish "$@"
fi

echo "Error: nscde-runtime not found for labwc keybind publishing." >&2
exit 1
