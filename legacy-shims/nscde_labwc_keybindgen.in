#!@KSH@

#
# nscde_labwc_keybindgen - Generate labwc keyboard XML from NsCDE keybindings
#
# Reads:
#   - $NSCDE_DATADIR/fvwm/Keybindings.cua (system default keybinding set)
#   - Environment: NSCDE_BACKEND, NSCDE_TOOLSDIR, NSCDE_DATADIR, FVWM_USERDIR
#
# Outputs: labwc <keyboard> XML fragment to stdout
#

# Required environment
if [ -z "$NSCDE_DATADIR" ]; then
   echo "Error: NSCDE_DATADIR must be set." >&2
   exit 2
fi

FVWM_USERDIR="${FVWM_USERDIR:-${HOME}/.NsCDE}"

# Locate terminal command
find_terminal()
{
   for term in weston-terminal xterm; do
      if command -v "$term" >/dev/null 2>&1; then
         echo "$term"
         return
      fi
   done
   echo "weston-terminal"
}

TERMINAL=$(find_terminal)

# Determine keybinding set to use
# Follows the same logic as FVWM Keybindings.fvwmconf:
# check kbd_bind_set, fall back to "cua"
_kbd_set="${NSCDE_KBD_BIND_SET:-cua}"
_keybind_file=""

if [ -r "$FVWM_USERDIR/Keybindings.${_kbd_set}" ]; then
   _keybind_file="$FVWM_USERDIR/Keybindings.${_kbd_set}"
elif [ -r "$NSCDE_DATADIR/fvwm/Keybindings.${_kbd_set}" ]; then
   _keybind_file="$NSCDE_DATADIR/fvwm/Keybindings.${_kbd_set}"
elif [ -r "$NSCDE_DATADIR/fvwm/Keybindings.cua" ]; then
   _keybind_file="$NSCDE_DATADIR/fvwm/Keybindings.cua"
fi

if [ -z "$_keybind_file" ]; then
   echo "Warning: No keybindings file found, generating defaults only." >&2
fi

# Map FVWM modifier string to labwc modifier string.
# FVWM: A=any, C=control, S=shift, M=meta(alt), N=nothing, 4=super(mod4)
# labwc: W=super, A=alt, C=ctrl, S=shift
# Multiple modifiers are concatenated (e.g., CS4 = Ctrl+Shift+Super)
map_modifier()
{
   _mod_in="$1"
   _mod_out=""

   # Handle empty or "N" (no modifier)
   case "$_mod_in" in
      N|"") echo ""; return ;;
      A) echo ""; return ;;  # "Any" - no specific modifier prefix
   esac

   # Parse each character
   _remaining="$_mod_in"
   while [ -n "$_remaining" ]; do
      _char="${_remaining%${_remaining#?}}"
      _remaining="${_remaining#?}"
      case "$_char" in
         C) _mod_out="${_mod_out}C-" ;;
         S) _mod_out="${_mod_out}S-" ;;
         M) _mod_out="${_mod_out}A-" ;;
         4) _mod_out="${_mod_out}W-" ;;
         A) ;; # "Any" modifier - skip
         *) ;; # Unknown - skip
      esac
   done

   echo "$_mod_out"
}

# Map a FVWM key name to a labwc key name.
map_key()
{
   _key="$1"
   case "$_key" in
      Return) echo "Return" ;;
      Tab) echo "Tab" ;;
      Escape) echo "Escape" ;;
      Space) echo "Space" ;;
      BackSpace) echo "BackSpace" ;;
      Delete) echo "Delete" ;;
      Home) echo "Home" ;;
      End) echo "End" ;;
      Page_Up|Prior) echo "Prior" ;;
      Page_Down|Next) echo "Next" ;;
      Insert) echo "Insert" ;;
      Up) echo "Up" ;;
      Down) echo "Down" ;;
      Left) echo "Left" ;;
      Right) echo "Right" ;;
      F1) echo "F1" ;;
      F2) echo "F2" ;;
      F3) echo "F3" ;;
      F4) echo "F4" ;;
      F5) echo "F5" ;;
      F6) echo "F6" ;;
      F7) echo "F7" ;;
      F8) echo "F8" ;;
      F9) echo "F9" ;;
      F10) echo "F10" ;;
      F11) echo "F11" ;;
      F12) echo "F12" ;;
      Menu) echo "Menu" ;;
      # XF86 keys pass through as-is
      XF86*) echo "$_key" ;;
      # Sun keyboard keys - pass through capitalized
      Sun*) echo "$_key" ;;
      # Single letter keys
      ?) echo "$_key" ;;
      # Multi-char keys that are not special - lowercase for labwc
      *) echo "$_key" | tr 'A-Z' 'a-z' ;;
   esac
}

# Map FVWM action to labwc action XML.
# Returns 0 if mapping produced, 1 if action should be skipped.
map_action()
{
   _act="$1"

   case "$_act" in
      # Scroll <x> <y> -> workspace navigation (approximate)
      Scroll\ 0\ 100000)
         printf '      <action name="GoToDesktop" to="right" wrap="yes" />\n'
         return 0
         ;;
      Scroll\ 0\ -100000)
         printf '      <action name="GoToDesktop" to="left" wrap="yes" />\n'
         return 0
         ;;
      Scroll\ *)
         # Generic scroll - skip (page scrolling has no labwc equivalent)
         return 1
         ;;
      # f_GotoDesk -> GoToDesktop
      f_GotoDesk\ *)
         return 1
         ;;
      # NextWindow / focus cycling
      Next\ *AcceptsFocus*|Next\ *FlipFocus*|Next\ *Focus*)
         printf '      <action name="NextWindow" />\n'
         return 0
         ;;
      Prev\ *AcceptsFocus*|Prev\ *FlipFocus*|Prev\ *Focus*)
         printf '      <action name="PreviousWindow" />\n'
         return 0
         ;;
      # Close
      Close)
         printf '      <action name="Close" />\n'
         return 0
         ;;
      # Iconify / minimize
      Iconify)
         printf '      <action name="Iconify" />\n'
         return 0
         ;;
      # Maximize
      Maximize)
         printf '      <action name="ToggleMaximize" />\n'
         return 0
         ;;
      f_ButtonMaximize*)
         printf '      <action name="ToggleMaximize" />\n'
         return 0
         ;;
      # WindowShade
      WindowShade*)
         printf '      <action name="ToggleShade" />\n'
         return 0
         ;;
      # Raise / Lower
      Raise)
         printf '      <action name="Raise" />\n'
         return 0
         ;;
      Lower)
         printf '      <action name="Lower" />\n'
         return 0
         ;;
      RaiseLower)
         printf '      <action name="ToggleAlwaysOnTop" />\n'
         return 0
         ;;
      # Move
      Move)
         printf '      <action name="Move" />\n'
         return 0
         ;;
      # Resize
      *Resize*|f_StatefulResize*)
         printf '      <action name="Resize" />\n'
         return 0
         ;;
      # Exec / Execute
      Exec\ exec\ *)
         _cmd="${_act#Exec exec }"
         # Strip quotes
         _cmd="${_cmd%\"}"
         _cmd="${_cmd#\"}"
         # Skip FVWM variable references
         case "$_cmd" in
            *'$['*) return 1 ;;
         esac
         printf '      <action name="Execute"><command>%s</command></action>\n' "$_cmd"
         return 0
         ;;
      Exec\ *)
         _cmd="${_act#Exec }"
         _cmd="${_cmd%\"}"
         _cmd="${_cmd#\"}"
         # Skip FVWM variable references
         case "$_cmd" in
            *'$['*) return 1 ;;
         esac
         printf '      <action name="Execute"><command>%s</command></action>\n' "$_cmd"
         return 0
         ;;
      # Menu calls -> ShowMenu
      Menu\ MenuFvwmRoot*|Menu\ m_WindowOpsRootWin*)
         printf '      <action name="ShowMenu" menu="root-menu" />\n'
         return 0
         ;;
      Menu\ *)
         # Other menus - show root menu as fallback
         printf '      <action name="ShowMenu" menu="root-menu" />\n'
         return 0
         ;;
      # f_RootMenu -> ShowMenu
      f_RootMenu)
         printf '      <action name="ShowMenu" menu="root-menu" />\n'
         return 0
         ;;
      # WindowList -> client-list-combined-menu
      WindowList*|f_WinLists*)
         printf '      <action name="ShowMenu" menu="client-list-combined-menu" />\n'
         return 0
         ;;
      # Refresh
      Refresh)
         printf '      <action name="Reconfigure" />\n'
         return 0
         ;;
      # Nop
      Nop)
         return 1
         ;;
      # FVWM-only commands - skip
      f_GotoDesk*|f_SwitchFocus*|f_FlipOverlapped*|f_BrowseIcons*|f_ToggleFvwm*|f_ShowFPPGMenu*|f_TileWindows*|f_Zoom*|f_Rofi*|f_CleanRestore*|f_RaiseLowerX*|f_SendToOccupy*|f_Find*|f_KeyFromFp*|f_KeyFromSub*|f_Mixer*|f_WideTerm*|f_DoubleBindKey*|f_KeyShowLocalPager*|f_ShowGlobalPager*|f_HideLocalPager*|f_RepositionWindow*|f_Xscreensaver*|f_ToggleExecWindow*|f_DisplayURL*|f_RunQuickScriptDialog*|f_RestoreFrontPanel*|f_IconOps*)
         return 1
         ;;
      # SendToModule - FVWM-only
      SendToModule*)
         return 1
         ;;
      # CursorMove - no direct equivalent
      CursorMove*)
         return 1
         ;;
      # FakeClick - FVWM-only
      FakeClick*)
         return 1
         ;;
      # WarpToWindow - no direct equivalent
      WarpToWindow*)
         return 1
         ;;
      # Anything with FVWM-specific syntax or variables
      *'$['*|*f_*|*CurrentPage*|*CurrentDesk*|*ThisWindow*|*FrontPanel*|*Subpanel*|*Occupy*|*GWM*|*LocalPager*|*Iconic*|*IconMan*|*FvwmScript*|*FvwmButtons*|*FvwmPager*)
         return 1
         ;;
      # Generic fallback: try Execute
      *)
         return 1
         ;;
   esac
}

# Emit a <keybind> block to the temp file
emit_keybind()
{
   _fvwm_key="$1"
   _fvwm_context="$2"
   _fvwm_modifier="$3"
   _fvwm_action="$4"

   # Skip context-specific bindings that have no labwc equivalent
   # R=Root, W=Window, F=Frame, S=Side, T=Title, I=Icon
   # We only map R (root/global) and A (any) contexts for global keys
   # and W (window) context for window-specific keys
   case "$_fvwm_context" in
      R|A) ;; # global contexts - acceptable
      W) ;; # window context - acceptable
      F|S|T|I) return ;; # skip frame-specific contexts
      FrontPanel*|NsCDE*|*term*|*terminal*|LocalPager*|GWMPager*|GlobalPager*) return ;; # skip named contexts
      *) return ;;
   esac

   # Map key
   _labwc_key=$(map_key "$_fvwm_key")
   [ -z "$_labwc_key" ] && return

   # Map modifier
   _labwc_mod=$(map_modifier "$_fvwm_modifier")
   _full_key="${_labwc_mod}${_labwc_key}"

   # Map action
   _action_xml=$(map_action "$_fvwm_action")
   if [ $? -ne 0 ]; then
      return
   fi

   [ -z "$_action_xml" ] && return

   # Write to temp file for deduplication: key<TAB>action_xml
   printf '%s\t%s\n' "$_full_key" "$_action_xml" >> "$_tmpbinds"
}

# Generate the keyboard XML section
generate_keyboard()
{
   # Use a temp file for collecting and deduplicating keybindings
   _tmpbinds=$(mktemp 2>/dev/null || echo "/tmp/nscde_keybinds_$$.tmp")
   trap "rm -f $_tmpbinds" EXIT

   # Parse FVWM keybindings file first (lower priority)
   if [ -n "$_keybind_file" ]; then
      # Read keybindings, skip comments and blank lines
      while IFS= read -r _line; do
         # Strip leading/trailing whitespace
         _line=$(printf '%s' "$_line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

         # Skip comments, blank lines, directives
         case "$_line" in
            '#'*|''|Test\ *|InfoStoreAdd*|Silent\ PointerKey*) continue ;;
         esac

         # Parse: [Silent] Key <key> <context> <modifier> <action>
         # Strip "Silent " prefix
         _rest="$_line"
         case "$_rest" in
            Silent\ *) _rest="${_rest#Silent }" ;;
         esac

         # Must start with "Key "
         case "$_rest" in
            Key\ *) _rest="${_rest#Key }" ;;
            *) continue ;;
         esac

         # Extract key (first word)
         _key="${_rest%% *}"
         _rest="${_rest#$_key }"

         # Extract context (second word)
         _ctx="${_rest%% *}"
         _rest="${_rest#$_ctx }"

         # Extract modifier (third word)
         _mod="${_rest%% *}"
         _rest="${_rest#$_mod }"

         # Remaining is the action
         _action="$_rest"

         # Skip empty actions
         [ -z "$_action" ] && continue

         # Emit keybind
         emit_keybind "$_key" "$_ctx" "$_mod" "$_action"
      done < "$_keybind_file"
   fi

   # Add volume/media keys (common NsCDE pattern)
   cat >> "$_tmpbinds" <<MEDIA_KEYS
XF86AudioLowerVolume	  <action name="Execute"><command>pactl set-sink-volume @DEFAULT_SINK@ -5%</command></action>
XF86AudioRaiseVolume	  <action name="Execute"><command>pactl set-sink-volume @DEFAULT_SINK@ +5%</command></action>
XF86AudioMute	  <action name="Execute"><command>pactl set-sink-mute @DEFAULT_SINK@ toggle</command></action>
A-Home	  <action name="Execute"><command>sh -c "QT_QPA_PLATFORM=wayland NSCDE_BACKEND=labwc NSCDE_TOOLSDIR=${NSCDE_TOOLSDIR} NSCDE_DATADIR=${NSCDE_DATADIR} ${NSCDE_TOOLSDIR}/nscde_labwc_stylemgr"</command></action>
MEDIA_KEYS

   # Add NsCDE-specific keybindings last (highest priority - override FVWM)
   cat >> "$_tmpbinds" <<'NSCDE_KEYS'
W-Return	  <action name="Execute"><command>TERMINAL_PLACEHOLDER</command></action>
Menu	  <action name="ShowMenu" menu="root-menu" />
A-Space	  <action name="ShowMenu" menu="root-menu" />
A-Escape	  <action name="ShowMenu" menu="client-list-combined-menu" />
C-Left	  <action name="GoToDesktop" to="left" wrap="yes" />
C-Right	  <action name="GoToDesktop" to="right" wrap="yes" />
C-Up	  <action name="GoToDesktop" to="up" wrap="yes" />
C-Down	  <action name="GoToDesktop" to="down" wrap="yes" />
A-Tab	  <action name="NextWindow" />
A-S-Tab	  <action name="PreviousWindow" />
A-F4	  <action name="Close" />
W-Home	  <action name="ShowMenu" menu="client-list-combined-menu" />
NSCDE_KEYS

   # Emit header
   printf '  <keyboard>\n'
   printf '    <default />\n'

   # Deduplicate: for each unique key, keep the last definition
   # This ensures FVWM-parsed bindings override hardcoded defaults
   # Use awk to keep last occurrence of each key
   sort -t'	' -k1,1 "$_tmpbinds" | awk -F'\t' '
   {
      keys[$1] = $2
   }
   END {
      # Emit in the order keys first appeared (approximate via sorted order)
      for (k in keys) {
         printf "    <keybind key=\"%s\">\n", k
         printf "      %s\n", keys[k]
         printf "    </keybind>\n"
      }
   }'

   printf '  </keyboard>\n'
}

# Main
generate_keyboard | sed "s|TERMINAL_PLACEHOLDER|${TERMINAL}|g"
