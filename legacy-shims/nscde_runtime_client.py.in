#!@PYTHON@

import os
import socket

try:
    from PyQt5.QtCore import QSocketNotifier
except ImportError:
    QSocketNotifier = None


PALETTE_KEYS = [
    "NSCDE_PALETTE_1",
    "NSCDE_PALETTE_2",
    "NSCDE_PALETTE_3",
    "NSCDE_PALETTE_4",
    "NSCDE_PALETTE_5",
    "NSCDE_PALETTE_6",
    "NSCDE_PALETTE_7",
    "NSCDE_PALETTE_8",
]

DEFAULT_PALETTE = [
    "#b7c1ca",
    "#101010",
    "#8a9baa",
    "#4f5964",
    "#355d84",
    "#355d84",
    "#6b7785",
    "#e7e7e7",
]


def state_dir():
    state = os.environ.get("NSCDE_STATE_DIR", "")
    if state:
        return state
    cache_home = os.environ.get(
        "XDG_CACHE_HOME", os.path.join(os.path.expanduser("~"), ".cache")
    )
    return os.path.join(cache_home, "nscde-stage1")


def state_path(name):
    return os.path.join(state_dir(), name)


def panel_env_path():
    return state_path("panel.env")


def style_env_path():
    return state_path("style.env")


def workspaces_env_path():
    return state_path("workspaces.env")


def windows_env_path():
    return state_path("windows.env")


def pager_env_path():
    return state_path("pager.env")


def session_fifo_path():
    return state_path("sessiond.fifo")


def pager_fifo_path():
    state = parse_env_file(workspaces_env_path())
    fifo = state.get("NSCDE_PAGER_COMMAND_FIFO", "")
    if fifo:
        return fifo
    state = parse_env_file(pager_env_path())
    fifo = state.get("NSCDE_PAGER_COMMAND_FIFO", "")
    if fifo:
        return fifo
    return state_path("pagerd.fifo")


def toplevel_fifo_path():
    state = query_state("windows")
    fifo = state.get("NSCDE_TASK_COMMAND_FIFO", "")
    if fifo:
        return fifo
    fifo = state.get("NSCDE_TASKD_COMMAND_FIFO", "")
    if fifo:
        return fifo
    return state_path("topleveld.fifo")


def parse_env_file(path):
    if not os.path.exists(path):
        return {}
    with open(path, "r", encoding="utf-8") as handle:
        return parse_env_contents(handle.read())


def parse_env_contents(contents):
    data = {}
    for line in contents.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        data[key] = value
    return data


def runtime_bin():
    return os.environ.get("NSCDE_RUNTIME_BIN", "nscde-runtime")


def runtime_socket_path():
    return state_path("runtime.sock")


def render_env_frame(entries):
    return "".join(
        "{}={}\n".format(key, value) for key, value in _iter_entries(entries)
    ) + "\n"


def runtime_request_frame(entries):
    try:
        client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        client.connect(runtime_socket_path())
        client.sendall(render_env_frame(entries).encode("utf-8"))
        chunks = []
        while True:
            chunk = client.recv(4096)
            if not chunk:
                break
            chunks.append(chunk)
            if b"\n\n" in chunk or b"\n\n" in b"".join(chunks):
                break
        client.close()
    except (FileNotFoundError, OSError):
        return None

    payload = b"".join(chunks).decode("utf-8", errors="replace")
    frame_text = payload.split("\n\n", 1)[0]
    return parse_env_contents(frame_text)


def runtime_query_state(topic):
    response = runtime_request_frame({
        "TYPE": "query",
        "TOPIC": topic,
    })
    if response is None:
        return None
    if response.get("TYPE", "") != "state":
        return None
    response_topic = response.get("TOPIC", "")
    if response_topic and response_topic != topic:
        return None
    return strip_meta(response)


def runtime_ctl(*args):
    frame = build_runtime_ctl_frame(args)
    if not frame:
        return False
    response = runtime_request_frame(frame)
    if response is None:
        return False
    return response.get("TYPE", "") == "ack"


def runtime_style_set(style_values, apply=False):
    frame = {
        "TYPE": "command",
        "NAME": "style-set",
        "APPLY": "1" if apply else "0",
    }
    frame.update(style_values)
    response = runtime_request_frame(frame)
    if response is None:
        return False
    return response.get("TYPE", "") == "ack"


def runtime_style_apply():
    response = runtime_request_frame({
        "TYPE": "command",
        "NAME": "style-apply",
    })
    if response is None:
        return False
    return response.get("TYPE", "") == "ack"


def runtime_refresh(target):
    response = runtime_request_frame({
        "TYPE": "command",
        "NAME": "refresh",
        "TARGET": target,
    })
    if response is None:
        return False
    return response.get("TYPE", "") == "ack"


def runtime_color_select(palette_name, color_count):
    response = runtime_request_frame({
        "TYPE": "command",
        "NAME": "color-select",
        "PALETTE": palette_name,
        "COLORS": str(color_count),
    })
    if response is None:
        return False
    return response.get("TYPE", "") == "ack"


def runtime_backdrop_select(desk_number, mode, image_name):
    response = runtime_request_frame({
        "TYPE": "command",
        "NAME": "backdrop-select",
        "DESK": str(desk_number),
        "MODE": mode,
        "IMAGE": image_name,
    })
    if response is None:
        return False
    return response.get("TYPE", "") == "ack"


def write_fifo_command(path, command_line):
    try:
        fd = os.open(path, os.O_WRONLY | os.O_NONBLOCK)
    except OSError:
        return False

    try:
        os.write(fd, (command_line + "\n").encode("utf-8"))
        return True
    except OSError:
        return False
    finally:
        os.close(fd)


def runtime_workspace_switch(workspace_name):
    runtime_success = runtime_ctl("workspace-switch", workspace_name)
    switch_success = write_fifo_command(
        pager_fifo_path(),
        "switch_workspace:{}".format(workspace_name),
    )
    return runtime_success, switch_success


def query_state(topic):
    state = runtime_query_state(topic)
    if state is None:
        raise RuntimeUnavailableError(
            "Unable to query runtime topic '{}' via {}".format(
                topic, runtime_socket_path()
            )
        )
    return state


def panel_state():
    return query_state("panel")


def style_state():
    return query_state("style")


def workspaces_state():
    return query_state("workspaces")


def windows_state():
    return query_state("windows")


def split_topic_list(topics):
    if isinstance(topics, str):
        raw_topics = topics.split(",")
    else:
        raw_topics = list(topics)
    return [topic.strip() for topic in raw_topics if topic and topic.strip()]


def runtime_subscribe_socket(topics):
    topic_list = split_topic_list(topics)
    if not topic_list:
        raise OSError("no topics requested")
    client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    client.connect(runtime_socket_path())
    client.sendall(render_env_frame({
        "TYPE": "subscribe",
        "TOPICS": ",".join(topic_list),
    }).encode("utf-8"))
    client.setblocking(False)
    return client


class RuntimeSubscription(object):
    def __init__(self, topics, parent=None):
        if QSocketNotifier is None:
            raise RuntimeError("PyQt5 QtCore is required for runtime subscriptions")
        self._topics = split_topic_list(topics)
        self._parent = parent
        self._socket = None
        self._notifier = None
        self._buffer = b""
        self._cache = {}
        self._topic_handlers = {}
        self._frame_handlers = []
        self._closed = False
        self._connect()

    def close(self):
        self._closed = True
        self._teardown_socket()

    def on_frame(self, handler):
        self._frame_handlers.append(handler)

    def on_topic(self, topic, handler):
        topic_key = topic.strip()
        self._topic_handlers.setdefault(topic_key, []).append(handler)
        cached = self._cache.get(topic_key)
        if cached is not None:
            handler(cached)

    def state(self, topic):
        cached = self._cache.get(topic)
        if cached is not None:
            return dict(cached)
        return query_state(topic)

    def _connect(self):
        if self._closed:
            return False
        self._teardown_socket()
        try:
            self._socket = runtime_subscribe_socket(self._topics)
        except OSError:
            self._socket = None
            raise RuntimeUnavailableError(
                "Unable to subscribe to runtime topics '{}' via {}".format(
                    ",".join(self._topics), runtime_socket_path()
                )
            )

        self._buffer = b""
        self._notifier = QSocketNotifier(
            self._socket.fileno(), QSocketNotifier.Read, self._parent
        )
        self._notifier.activated.connect(self._on_ready_read)
        return True

    def _teardown_socket(self):
        if self._notifier is not None:
            self._notifier.setEnabled(False)
            self._notifier.deleteLater()
            self._notifier = None
        if self._socket is not None:
            try:
                self._socket.close()
            except OSError:
                pass
            self._socket = None

    def _disconnect(self):
        self._teardown_socket()
        if not self._closed:
            self._handle_runtime_failure(
                RuntimeDisconnectedError(
                    "Runtime subscription disconnected for topics '{}'".format(
                        ",".join(self._topics)
                    )
                )
            )

    def _on_ready_read(self, _fd):
        if self._socket is None:
            return
        while True:
            try:
                chunk = self._socket.recv(4096)
            except BlockingIOError:
                break
            except InterruptedError:
                continue
            except OSError:
                self._disconnect()
                return

            if not chunk:
                self._disconnect()
                return
            self._buffer += chunk

        self._drain_frames()

    def _drain_frames(self):
        while b"\n\n" in self._buffer:
            frame_bytes, _, rest = self._buffer.partition(b"\n\n")
            self._buffer = rest
            frame = parse_env_contents(frame_bytes.decode("utf-8", errors="replace"))
            if not frame:
                continue
            self._handle_frame(frame)

    def _handle_frame(self, frame):
        frame_type = frame.get("TYPE", "")
        topic = frame.get("TOPIC", "")
        payload = strip_meta(frame)

        for handler in self._frame_handlers:
            handler(frame_type, topic, dict(payload))

        if frame_type != "state" or not topic:
            if frame_type == "error":
                self._teardown_socket()
                if not self._closed:
                    self._handle_runtime_failure(
                        RuntimeDisconnectedError(
                            "Runtime subscription error for '{}': {}".format(
                                ",".join(self._topics),
                                frame.get("MESSAGE", "unknown error"),
                            )
                        )
                    )
            return

        self._cache[topic] = dict(payload)
        for handler in self._topic_handlers.get(topic, []):
            handler(dict(payload))

    def _handle_runtime_failure(self, error):
        if self._closed:
            return
        self._closed = True
        if self._parent is not None:
            show_runtime_error(self._parent, "Runtime Error", error)
            close = getattr(self._parent, "close", None)
            if callable(close):
                close()
            return
        raise error


def read_palette(state, palette_keys=PALETTE_KEYS, default_palette=DEFAULT_PALETTE):
    palette = []
    for key in palette_keys:
        color = state.get(key, "")
        if color and color.startswith("#") and len(color) == 7:
            palette.append(color)
        else:
            palette.append(None)
    return [p or d for p, d in zip(palette, default_palette)]


def strip_meta(entries):
    return {
        key: value
        for key, value in entries.items()
        if key not in ("TYPE", "TOPIC", "MESSAGE")
    }


def build_runtime_ctl_frame(args):
    if not args:
        return None

    command = args[0]
    if command == "workspace-switch" and len(args) == 2:
        return {
            "TYPE": "command",
            "NAME": "workspace-switch",
            "WORKSPACE": args[1],
        }
    if command == "workspace-rename" and len(args) == 3:
        return {
            "TYPE": "command",
            "NAME": "workspace-rename",
            "OLD": args[1],
            "NEW": args[2],
        }
    if command == "color-select" and len(args) == 3:
        return {
            "TYPE": "command",
            "NAME": "color-select",
            "PALETTE": args[1],
            "COLORS": args[2],
        }
    if command == "backdrop-select" and len(args) == 4:
        return {
            "TYPE": "command",
            "NAME": "backdrop-select",
            "DESK": args[1],
            "MODE": args[2],
            "IMAGE": args[3],
        }
    if command == "reload" and len(args) == 1:
        return {
            "TYPE": "command",
            "NAME": "reload",
        }
    if command == "refresh" and len(args) == 2:
        return {
            "TYPE": "command",
            "NAME": "refresh",
            "TARGET": args[1],
        }
    if command == "logout" and len(args) == 1:
        return {
            "TYPE": "command",
            "NAME": "logout",
        }
    if command == "failsafe" and len(args) == 1:
        return {
            "TYPE": "command",
            "NAME": "failsafe",
        }
    if command == "power" and len(args) == 2:
        return {
            "TYPE": "command",
            "NAME": "power",
            "ACTION": args[1],
        }
    if command == "window" and len(args) == 3:
        return {
            "TYPE": "command",
            "NAME": "window-{}".format(args[1]),
            "ID": args[2],
        }
    return None


class RuntimeUnavailableError(RuntimeError):
    pass


class RuntimeDisconnectedError(RuntimeError):
    pass


def show_runtime_error(parent, title, error):
    from PyQt5.QtWidgets import QMessageBox

    QMessageBox.critical(parent, title, str(error))


def _iter_entries(entries):
    if hasattr(entries, "items"):
        return entries.items()
    return entries
