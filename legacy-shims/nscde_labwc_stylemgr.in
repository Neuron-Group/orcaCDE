#!@PYTHON@

import os
import subprocess
import sys
from PyQt5.QtCore import Qt
from PyQt5.QtWidgets import (
    QApplication,
    QFrame,
    QHBoxLayout,
    QLabel,
    QPushButton,
    QVBoxLayout,
    QWidget,
)

import nscde_runtime_client as runtime_client

DEFAULT_PALETTE = runtime_client.DEFAULT_PALETTE


def nscde_toolsdir():
    toolsdir = os.environ.get("NSCDE_TOOLSDIR", "")
    if toolsdir:
        return toolsdir
    home = os.path.expanduser("~")
    user_dir = os.path.join(home, ".NsCDE", "nscde_tools")
    if os.path.isdir(user_dir):
        return user_dir
    return "/usr/share/NsCDE/nscde_tools"


def build_stylesheet(pal):
    bg = pal[0]
    fg = pal[1]
    hi = pal[2]
    sh = pal[3]
    acc = pal[5]
    sbg = pal[6]
    sfg = pal[7]

    return """
            QWidget#NsCDEStyleMgr {{
                background-color: {sbg};
            }}
            QFrame#mainFrame {{
                background-color: {sbg};
                border-top: 2px solid {hi};
                border-left: 2px solid {hi};
                border-right: 2px solid {sh};
                border-bottom: 2px solid {sh};
            }}
            QLabel {{
                color: {sfg};
                font-family: Sans;
                font-size: 10pt;
                font-weight: bold;
                background-color: transparent;
            }}
            QLabel#titleLabel {{
                font-size: 12pt;
                font-weight: bold;
            }}
            QPushButton {{
                color: {sfg};
                font-family: Sans;
                font-size: 10pt;
                font-weight: bold;
                min-width: 70px;
                min-height: 60px;
                padding: 4px 8px;
                background-color: {sbg};
                border-top: 2px solid {hi};
                border-left: 2px solid {hi};
                border-right: 2px solid {sh};
                border-bottom: 2px solid {sh};
            }}
            QPushButton:pressed {{
                background-color: {acc};
                color: #ffffff;
                border-top: 2px solid {sh};
                border-left: 2px solid {sh};
                border-right: 2px solid {hi};
                border-bottom: 2px solid {hi};
            }}
            QPushButton:disabled {{
                color: {sh};
            }}
            """.format(
        bg=bg, fg=fg, hi=hi, sh=sh, acc=acc, sbg=sbg, sfg=sfg
    )


MANAGER_BUTTONS = [
    ("Color", "color", True),
    ("Font", "font", True),
    ("Backdrop", "backdrop", True),
    ("Keyboard", "keyboard", False),
    ("Mouse", "mouse", False),
    ("Beep", "beep", False),
    ("Screen", "screen", False),
    ("Window", "window", True),
    ("Desks", "desks", True),
    ("Power", "power", True),
    ("Startup", "startup", False),
]


class NsCDEStyleMgr(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Style Manager")
        self.setObjectName("NsCDEStyleMgr")
        self.setMinimumWidth(790)

        self.current_palette = list(DEFAULT_PALETTE)
        self.capabilities = {}
        self._runtime_subscription = None
        self._build_ui()
        self._apply_stylesheet()
        self._setup_runtime_subscription()

    def _build_ui(self):
        main_layout = QVBoxLayout(self)
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)

        frame = QFrame()
        frame.setObjectName("mainFrame")
        frame_layout = QVBoxLayout(frame)
        frame_layout.setContentsMargins(8, 8, 8, 8)
        frame_layout.setSpacing(8)

        title = QLabel("NsCDE Style Manager")
        title.setObjectName("titleLabel")
        title.setAlignment(Qt.AlignCenter)
        frame_layout.addWidget(title)

        btn_row = QHBoxLayout()
        btn_row.setSpacing(6)

        self.buttons = {}
        for label, key, implemented in MANAGER_BUTTONS:
            btn = QPushButton(label)
            btn.setToolTip("{} Style Manager".format(label))
            if implemented:
                btn.clicked.connect(lambda checked, k=key: self._launch_manager(k))
            else:
                btn.setEnabled(False)
            self.buttons[key] = btn
            btn_row.addWidget(btn)

        frame_layout.addLayout(btn_row)

        close_row = QHBoxLayout()
        close_row.addStretch()
        close_btn = QPushButton("Close")
        close_btn.setFixedWidth(100)
        close_btn.clicked.connect(self.close)
        close_row.addWidget(close_btn)
        frame_layout.addLayout(close_row)

        main_layout.addWidget(frame)

    def _apply_stylesheet(self):
        state = runtime_client.panel_state()
        pal = runtime_client.read_palette(state)
        self.current_palette = pal
        self.setStyleSheet(build_stylesheet(pal))

    def _setup_runtime_subscription(self):
        try:
            self._runtime_subscription = runtime_client.RuntimeSubscription(
                ["panel", "capabilities"], self
            )
        except RuntimeError as err:
            self._runtime_subscription = None
            runtime_client.show_runtime_error(self, "Runtime Error", err)
            self.close()
            return

        self._runtime_subscription.on_topic("panel", self._handle_panel_state)
        self._runtime_subscription.on_topic(
            "capabilities", self._handle_capabilities_state
        )

    def _handle_panel_state(self, state):
        pal = runtime_client.read_palette(state)
        if pal != self.current_palette:
            self.current_palette = pal
            self.setStyleSheet(build_stylesheet(pal))

    def _handle_capabilities_state(self, state):
        self.capabilities = dict(state)
        self._update_runtime_buttons()

    def _launch_manager(self, key):
        toolsdir = nscde_toolsdir()
        env = dict(os.environ)
        env.setdefault("NSCDE_TOOLSDIR", toolsdir)

        manager_map = {
            "color": "nscde_labwc_colormgr",
            "font": "nscde_labwc_fontmgr",
            "backdrop": "nscde_labwc_backdropmgr",
            "window": "nscde_labwc_windowmgr",
            "desks": "nscde_labwc_wsm",
            "power": "nscde_labwc_sysaction",
        }

        manager_script = manager_map.get(key)
        if manager_script:
            script_path = os.path.join(toolsdir, manager_script)
            if os.path.exists(script_path):
                subprocess.Popen([script_path], env=env)
                return

        launcher = os.path.join(toolsdir, "nscde_stylemgr")
        if os.path.exists(launcher):
            subprocess.Popen([launcher, key], env=env)

    def _update_runtime_buttons(self):
        power_button = self.buttons.get("power")
        if power_button is not None:
            power_button.setEnabled(
                self.capabilities.get("supports-power-shutdown", "0") == "1"
                or self.capabilities.get("supports-power-reboot", "0") == "1"
                or self.capabilities.get("supports-power-suspend", "0") == "1"
                or self.capabilities.get("supports-power-hybrid-suspend", "0") == "1"
                or self.capabilities.get("supports-power-hibernate", "0") == "1"
            )

    def closeEvent(self, event):
        if self._runtime_subscription is not None:
            self._runtime_subscription.close()
        super().closeEvent(event)


def main():
    app = QApplication(sys.argv)
    try:
        mgr = NsCDEStyleMgr()
        mgr.show()
        sys.exit(app.exec_())
    except RuntimeError as err:
        runtime_client.show_runtime_error(None, "Runtime Error", err)
        return 1


if __name__ == "__main__":
    main()
