# ============================================================
# Icon State Functions
# ============================================================

# Set icon placement mode
# Usage: nscde_style_set_icon_placement MODE
# MODE: 0 (workspace), 1 (iconbox)
function nscde_style_set_icon_placement
{
	local _mode="$1"
	nscde_style_set "NSCDE_ICON_PLACEMENT" "$_mode"
}

# Get icon placement mode
function nscde_style_get_icon_placement
{
	local _mode
	_mode=$(nscde_style_get "NSCDE_ICON_PLACEMENT")
	echo "${_mode:-0}"
}

# Set icon fill direction
# Usage: nscde_style_set_icon_fill DIRECTION
# DIRECTION: bottom.left, top.left, bottom.right, top.right
function nscde_style_set_icon_fill
{
	local _direction="$1"
	nscde_style_set "NSCDE_ICON_FILL" "$_direction"
}

# Get icon fill direction
function nscde_style_get_icon_fill
{
	local _direction
	_direction=$(nscde_style_get "NSCDE_ICON_FILL")
	echo "${_direction:-bottom.left}"
}

# Set icon size
# Usage: nscde_style_set_icon_size DEF_W DEF_H MAX_W MAX_H
function nscde_style_set_icon_size
{
	local _size="$1,$2,$3,$4"
	nscde_style_set "NSCDE_ICON_SIZE" "$_size"
}

# Get icon size (returns comma-separated values)
function nscde_style_get_icon_size
{
	local _size
	_size=$(nscde_style_get "NSCDE_ICON_SIZE")
	echo "${_size:-48,48,128,128}"
}

