#
# NsCDE style state management library.
#
# Provides normalized state storage for style managers, decoupling
# them from backend-specific configuration formats.
#
# This file is a part of NsCDE - Not so Common Desktop Environment
# Author: Hegel3DReloaded
# Licence: GPLv3
#

# State file for style settings
NSCDE_STYLE_STATE_FILE="${NSCDE_STATE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/nscde-stage1}/style.env"

# Ensure style state directory exists
function nscde_style_state_ensure
{
	local _dir
	_dir=$(dirname "$NSCDE_STYLE_STATE_FILE")
	if [ ! -d "$_dir" ]; then
		mkdir -p "$_dir" || return 1
	fi
	return 0
}

# Write a style state value
# Usage: nscde_style_set KEY VALUE
function nscde_style_set
{
	local _key="$1"
	local _value="$2"

	nscde_style_state_ensure || return 1

	# Use nscde_state_write from nscde_backend.shlib
	if type nscde_state_write >/dev/null 2>&1; then
		nscde_state_write "$NSCDE_STYLE_STATE_FILE" "$_key" "$_value"
	else
		# Fallback: direct file manipulation
		if grep -q "^${_key}=" "$NSCDE_STYLE_STATE_FILE" 2>/dev/null; then
			sed -i "s|^${_key}=.*|${_key}=${_value}|" "$NSCDE_STYLE_STATE_FILE"
		else
			echo "${_key}=${_value}" >> "$NSCDE_STYLE_STATE_FILE"
		fi
	fi
}

# Read a style state value
# Usage: nscde_style_get KEY
function nscde_style_get
{
	local _key="$1"

	if [ ! -f "$NSCDE_STYLE_STATE_FILE" ]; then
		return 1
	fi

	# Use nscde_state_read from nscde_backend.shlib if available
	if type nscde_state_read >/dev/null 2>&1; then
		nscde_state_read "$NSCDE_STYLE_STATE_FILE" "$_key"
	else
		# Fallback: direct grep
		grep "^${_key}=" "$NSCDE_STYLE_STATE_FILE" 2>/dev/null | cut -d= -f2-
	fi
}

# Remove a style state key
# Usage: nscde_style_unset KEY
function nscde_style_unset
{
	local _key="$1"

	if [ ! -f "$NSCDE_STYLE_STATE_FILE" ]; then
		return 0
	fi

	sed -i "/^${_key}=/d" "$NSCDE_STYLE_STATE_FILE"
}

# ============================================================
# Color/Palette State Functions
# ============================================================

# Set the active palette
# Usage: nscde_style_set_palette PALETTE_PATH
function nscde_style_set_palette
{
	local _palette_path="$1"
	local _palette_name

	# Extract name from path
	_palette_name=$(basename "$_palette_path" .dp)

	nscde_style_set "NSCDE_PALETTE_PATH" "$_palette_path"
	nscde_style_set "NSCDE_PALETTE_NAME" "$_palette_name"
}

# Get the active palette path
function nscde_style_get_palette_path
{
	nscde_style_get "NSCDE_PALETTE_PATH"
}

# Get the active palette name
function nscde_style_get_palette_name
{
	nscde_style_get "NSCDE_PALETTE_NAME"
}

# Set color mode (4 or 8 colors)
# Usage: nscde_style_set_color_mode MODE
function nscde_style_set_color_mode
{
	local _mode="$1"
	nscde_style_set "NSCDE_COLOR_MODE" "$_mode"
}

# Get color mode
function nscde_style_get_color_mode
{
	local _mode
	_mode=$(nscde_style_get "NSCDE_COLOR_MODE")
	echo "${_mode:-8}"
}

# Set Front Panel variant (5 or 8 color)
# Usage: nscde_style_set_fp_variant VARIANT
function nscde_style_set_fp_variant
{
	local _variant="$1"
	nscde_style_set "NSCDE_FP_VARIANT" "$_variant"
}

# Get Front Panel variant
function nscde_style_get_fp_variant
{
	local _variant
	_variant=$(nscde_style_get "NSCDE_FP_VARIANT")
	echo "${_variant:-8}"
}

# ============================================================
# Font State Functions
# ============================================================

# Set a font slot
# Usage: nscde_style_set_font SLOT FONT_SPEC
# SLOT format: variable.normal.small, monospaced.bold.large, etc.
function nscde_style_set_font
{
	local _slot="$1"
	local _font_spec="$2"
	nscde_style_set "NSCDE_FONT_${_slot}" "$_font_spec"
}

# Get a font slot
# Usage: nscde_style_get_font SLOT
function nscde_style_get_font
{
	local _slot="$1"
	nscde_style_get "NSCDE_FONT_${_slot}"
}

# Set the active fontset name
# Usage: nscde_style_set_fontset_name NAME
function nscde_style_set_fontset_name
{
	local _name="$1"
	nscde_style_set "NSCDE_FONTSET_NAME" "$_name"
}

# Get the active fontset name
function nscde_style_get_fontset_name
{
	nscde_style_get "NSCDE_FONTSET_NAME"
}

# Set font DPI
# Usage: nscde_style_set_font_dpi DPI
function nscde_style_set_font_dpi
{
	local _dpi="$1"
	nscde_style_set "NSCDE_FONT_DPI" "$_dpi"
}

# Get font DPI
function nscde_style_get_font_dpi
{
	local _dpi
	_dpi=$(nscde_style_get "NSCDE_FONT_DPI")
	echo "${_dpi:-96}"
}

# ============================================================
# Backdrop State Functions
# ============================================================

# Set backdrop for a desk
# Usage: nscde_style_set_backdrop DESK MODE IMAGE
# MODE: tiled, aspect, photo
function nscde_style_set_backdrop
{
	local _desk="$1"
	local _mode="$2"
	local _image="$3"
	nscde_style_set "NSCDE_BACKDROP_DESK_${_desk}_MODE" "$_mode"
	nscde_style_set "NSCDE_BACKDROP_DESK_${_desk}_IMAGE" "$_image"
}

# Get backdrop mode for a desk
# Usage: nscde_style_get_backdrop_mode DESK
function nscde_style_get_backdrop_mode
{
	local _desk="$1"
	nscde_style_get "NSCDE_BACKDROP_DESK_${_desk}_MODE"
}

# Get backdrop image for a desk
# Usage: nscde_style_get_backdrop_image DESK
function nscde_style_get_backdrop_image
{
	local _desk="$1"
	nscde_style_get "NSCDE_BACKDROP_DESK_${_desk}_IMAGE"
}

