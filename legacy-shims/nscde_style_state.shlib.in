# Set focus policy
# Usage: nscde_style_set_focus_policy POLICY
# POLICY: MouseFocus, SloppyFocus, ClickToFocus
function nscde_style_set_focus_policy
{
	local _policy="$1"
	nscde_style_set "NSCDE_FOCUS_POLICY" "$_policy"
}

# Get focus policy
function nscde_style_get_focus_policy
{
	local _policy
	_policy=$(nscde_style_get "NSCDE_FOCUS_POLICY")
	echo "${_policy:-MouseFocus}"
}

