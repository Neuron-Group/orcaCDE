# ============================================================
# Backend Config Generation Functions
# ============================================================

# Generate FVWM configuration from normalized state
# Usage: nscde_style_generate_fvwm_config
function nscde_style_generate_fvwm_config
{
	local _focus_policy _auto_raise _raise_delay _opaque_move _move_threshold
	local _raise_transient _lower_transient _stack_transient
	local _icon_placement _icon_fill _icon_size
	local _edge_thickness _edge_resistance _edge_move_resistance _edge_move_delay
	local _raise_fp_on_page _pager_preview
	local _animation_enabled _animation_effect _animation_delay _animation_twist
	local _animation_width _animation_iterations

	# Read normalized state
	_focus_policy=$(nscde_style_get_focus_policy)
	_auto_raise=$(nscde_style_get_auto_raise)
	_raise_delay=$(nscde_style_get_raise_delay)
	_opaque_move=$(nscde_style_get_opaque_move)
	_move_threshold=$(nscde_style_get_move_threshold)
	_raise_transient=$(nscde_style_get_raise_transient)
	_lower_transient=$(nscde_style_get_lower_transient)
	_stack_transient=$(nscde_style_get_stack_transient)
	_icon_placement=$(nscde_style_get_icon_placement)
	_icon_fill=$(nscde_style_get_icon_fill)
	_icon_size=$(nscde_style_get_icon_size)
	_edge_thickness=$(nscde_style_get_edge_thickness)
	_edge_resistance=$(nscde_style_get_edge_resistance)
	_edge_move_resistance=$(nscde_style_get_edge_move_resistance)
	_edge_move_delay=$(nscde_style_get_edge_move_delay)
	_raise_fp_on_page=$(nscde_style_get_raise_fp_on_page)
	_pager_preview=$(nscde_style_get_pager_preview)
	_animation_enabled=$(nscde_style_get_animation_enabled)
	_animation_effect=$(nscde_style_get_animation_effect)
	_animation_delay=$(nscde_style_get_animation_delay)
	_animation_twist=$(nscde_style_get_animation_twist)
	_animation_width=$(nscde_style_get_animation_width)
	_animation_iterations=$(nscde_style_get_animation_iterations)

	# Generate NsCDE.conf
	cat > "${FVWM_USERDIR}/NsCDE.conf" <<EOF
# NsCDE Window Manager Configuration
# Generated from normalized state - do not edit manually
# Edit via WindowMgr or style state tools

# Focus policy
Style * ${_focus_policy}

# Auto-raise
InfoStoreAdd autoraisefocus ${_auto_raise}
InfoStoreAdd afrmilisecs ${_raise_delay}

# Transient handling
Style * $([ "$_raise_transient" = "1" ] && echo "RaiseTransient" || echo "DontRaiseTransient")
Style * $([ "$_lower_transient" = "1" ] && echo "LowerTransient" || echo "DontLowerTransient")
Style * $([ "$_stack_transient" = "1" ] && echo "StackTransientParent" || echo "DontStackTransientParent")

# Opaque move
OpaqueMoveSize ${_opaque_move}

# Move threshold
MoveThreshold ${_move_threshold}

# Icon placement
InfoStoreAdd iconbox ${_icon_placement}
Style * IconFill ${_icon_fill%%.*} ${_icon_fill##*.}

# Icon size
Style * IconSize ${_icon_size//,/ }

# Page edges
EdgeThickness ${_edge_thickness}
EdgeResistance ${_edge_resistance}
Style * EdgeMoveResistance ${_edge_move_resistance}
Style * EdgeMoveDelay ${_edge_move_delay}
InfoStoreAdd pageraisefp ${_raise_fp_on_page}
InfoStoreAdd pageshowrootpager ${_pager_preview}
EOF

	# Generate Animate.fvwmgen
	cat > "${FVWM_USERDIR}/Animate.fvwmgen" <<EOF
# NsCDE Animation Configuration
# Generated from normalized state - do not edit manually

*FvwmAnimate: $([ "$_animation_enabled" = "1" ] && echo "Effect ${_animation_effect}" || echo "Effect None")
*FvwmAnimate: Delay ${_animation_delay}
*FvwmAnimate: Twist ${_animation_twist}
*FvwmAnimate: Width ${_animation_width}
*FvwmAnimate: Iterations ${_animation_iterations}
EOF
}

# Generate labwc configuration from normalized state
# Usage: nscde_style_generate_labwc_config
#
# For labwc, the primary config artifacts are:
# - themerc: generated by nscde_labwc_theme from the current palette
# - rc.xml: regenerated here with window behavior from normalized state
# - menu.xml: generated by nscde_labwc at session start
#
# This function records backend-specific intent, regenerates labwc
# theme when the palette has changed, and updates rc.xml with the
# current window behavior settings from normalized state.
function nscde_style_generate_labwc_config
{
	local _focus_policy _palette_path _palette_name
	local _auto_raise _raise_delay _edge_thickness
	local _rc_xml _follow_mouse _raise_on_focus

	_focus_policy=$(nscde_style_get_focus_policy)
	_palette_path=$(nscde_style_get_palette_path)
	_palette_name=$(nscde_style_get_palette_name)
	_auto_raise=$(nscde_style_get_auto_raise)
	_raise_delay=$(nscde_style_get_raise_delay)
	_edge_thickness=$(nscde_style_get_edge_thickness)

	# Record focus intent for labwc
	nscde_style_set "NSCDE_LABWC_FOCUS_INTENT" "$_focus_policy"

	# Map focus policy to labwc rc.xml values
	case "$_focus_policy" in
		ClickToFocus)
			_follow_mouse="no"
			_raise_on_focus="yes"
			;;
		SloppyFocus)
			_follow_mouse="yes"
			_raise_on_focus="no"
			;;
		*)
			_follow_mouse="yes"
			_raise_on_focus="no"
			;;
	esac

	# Update rc.xml focus and edge settings if config dir exists
	_rc_xml="${NSCDE_LABWC_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/labwc-nscde}/rc.xml"
	if [ -f "$_rc_xml" ]; then
		# Update followMouse
		if grep -q '<followMouse>' "$_rc_xml" 2>/dev/null; then
			sed -i "s|<followMouse>[^<]*</followMouse>|<followMouse>${_follow_mouse}</followMouse>|g" "$_rc_xml"
		fi
		# Update raiseOnFocus
		if grep -q '<raiseOnFocus>' "$_rc_xml" 2>/dev/null; then
			sed -i "s|<raiseOnFocus>[^<]*</raiseOnFocus>|<raiseOnFocus>${_raise_on_focus}</raiseOnFocus>|g" "$_rc_xml"
		fi
	fi

	# Regenerate labwc theme if palette is set and theme generator exists
	if [ -n "$_palette_path" ] && [ -r "$_palette_path" ]; then
		export NSCDE_PALETTE_FILE="$_palette_path"
		if [ -x "${NSCDE_TOOLSDIR}/nscde_labwc_theme" ]; then
			"${NSCDE_TOOLSDIR}/nscde_labwc_theme" >/dev/null 2>&1
		fi
	fi
}

# Generate backend-specific configuration from normalized state
# Usage: nscde_style_generate_config [BACKEND]
function nscde_style_generate_config
{
	local _backend="${1:-$NSCDE_BACKEND}"

	case "$_backend" in
		fvwm|fvwm3)
			nscde_style_generate_fvwm_config
			;;
		labwc)
			nscde_style_generate_labwc_config
			;;
		*)
			echo "Warning: Unknown backend $_backend" >&2
			;;
	esac
}

# ============================================================
# Migration Functions
# ============================================================

# Migrate existing FVWM config to normalized state
# Usage: nscde_style_migrate_from_fvwm
function nscde_style_migrate_from_fvwm
{
	local _nsCDE_conf="${FVWM_USERDIR}/NsCDE.conf"

	if [ ! -f "$_nsCDE_conf" ]; then
		return 0
	fi

	# Extract focus policy
	if grep -q "Style.*ClickToFocus" "$_nsCDE_conf"; then
		nscde_style_set_focus_policy "ClickToFocus"
	elif grep -q "Style.*SloppyFocus" "$_nsCDE_conf"; then
		nscde_style_set_focus_policy "SloppyFocus"
	else
		nscde_style_set_focus_policy "MouseFocus"
	fi

	# Extract auto-raise
	if grep -q "InfoStoreAdd autoraisefocus 1" "$_nsCDE_conf"; then
		nscde_style_set_auto_raise "1"
	else
		nscde_style_set_auto_raise "0"
	fi

	# Extract raise delay
	local _raise_delay
	_raise_delay=$(grep "InfoStoreAdd afrmilisecs" "$_nsCDE_conf" | awk '{print $3}')
	if [ -n "$_raise_delay" ]; then
		nscde_style_set_raise_delay "$_raise_delay"
	fi

	# Extract transient handling
	if grep -q "Style.*RaiseTransient" "$_nsCDE_conf"; then
		nscde_style_set_raise_transient "1"
	else
		nscde_style_set_raise_transient "0"
	fi

	if grep -q "Style.*LowerTransient" "$_nsCDE_conf"; then
		nscde_style_set_lower_transient "1"
	else
		nscde_style_set_lower_transient "0"
	fi

	if grep -q "Style.*StackTransientParent" "$_nsCDE_conf"; then
		nscde_style_set_stack_transient "1"
	else
		nscde_style_set_stack_transient "0"
	fi

	# Extract opaque move
	local _opaque_move
	_opaque_move=$(grep "OpaqueMoveSize" "$_nsCDE_conf" | awk '{print $2}')
	if [ -n "$_opaque_move" ]; then
		nscde_style_set_opaque_move "$_opaque_move"
	fi

	# Extract move threshold
	local _move_threshold
	_move_threshold=$(grep "MoveThreshold" "$_nsCDE_conf" | awk '{print $2}')
	if [ -n "$_move_threshold" ]; then
		nscde_style_set_move_threshold "$_move_threshold"
	fi

	# Extract edge thickness
	local _edge_thickness
	_edge_thickness=$(grep "EdgeThickness" "$_nsCDE_conf" | awk '{print $2}')
	if [ -n "$_edge_thickness" ]; then
		nscde_style_set_edge_thickness "$_edge_thickness"
	fi

	# Extract edge resistance
	local _edge_resistance
	_edge_resistance=$(grep "EdgeResistance" "$_nsCDE_conf" | awk '{print $2}')
	if [ -n "$_edge_resistance" ]; then
		nscde_style_set_edge_resistance "$_edge_resistance"
	fi

	# Extract icon placement
	if grep -q "InfoStoreAdd iconbox 1" "$_nsCDE_conf"; then
		nscde_style_set_icon_placement "1"
	else
		nscde_style_set_icon_placement "0"
	fi

	echo "Migrated FVWM configuration to normalized state"
}

# ============================================================
# Utility Functions
# ============================================================

# Dump all style state
# Usage: nscde_style_dump
function nscde_style_dump
{
	if [ -f "$NSCDE_STYLE_STATE_FILE" ]; then
		cat "$NSCDE_STYLE_STATE_FILE"
	else
		echo "# No style state file found"
	fi
}

# Reset all style state to defaults
# Usage: nscde_style_reset
function nscde_style_reset
{
	if [ -f "$NSCDE_STYLE_STATE_FILE" ]; then
		rm -f "$NSCDE_STYLE_STATE_FILE"
	fi
	echo "Style state reset to defaults"
}
