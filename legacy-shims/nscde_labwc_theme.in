#!/bin/sh

#
# Compatibility wrapper for Haskell-owned labwc theme publishing.
#

_runtime_bin="${NSCDE_RUNTIME_BIN:-nscde-runtime}"

if [ -z "${NSCDE_THEME_SHIM_BYPASS:-}" ] && command -v "$_runtime_bin" >/dev/null 2>&1; then
   exec "$_runtime_bin" labwc-theme publish
fi

echo "nscde_labwc_theme: runtime binary not found: $_runtime_bin" >&2
exit 127
