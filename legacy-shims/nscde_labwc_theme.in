#!@KSH@

#
# Stage-one labwc theme generator for NsCDE.
# Writes themerc and XBM button glyphs into the NsCDE-owned theme directory.
# Now supports palette-driven color generation from .dp palette files.
#

if [ -z "$HOME" ]; then
   echo "Error: HOME not set." >&2
   exit 2
fi

# Set minimal backend context if not already provided by the launcher
export NSCDE_BACKEND=${NSCDE_BACKEND:-labwc}
export NSCDE_ROOT=${NSCDE_ROOT:-@prefix@}

# Source the shared backend library
. "@NSCDE_TOOLSDIR@/nscde_backend.shlib"

# Initialize backend environment for XDG paths
nscde_backend_init || exit 2

THEME_DIR="${NSCDE_THEMES_DIR}/${NSCDE_THEME_NAME}/labwc"
mkdir -p "$THEME_DIR"

# Palette color derivation
#
# If NSCDE_PALETTE_FILE is set and readable, derive all theme colors from
# the palette. Otherwise fall back to the hardcoded CDE-like defaults.
#
# CDE palette .dp format: 8 lines of #RRRRGGGGBBBB (16-bit hex per channel)
# Index mapping (1-based):
#   1: Background    2: Foreground     3: Top shadow    4: Bottom shadow
#   5: Select        6: Accent         7: Secondary bg  8: Secondary fg

function _motif_color_field
{
   _mcf_color=$1
   _mcf_field=$2

   @PYTHON@ "$NSCDE_TOOLSDIR/palette_colorgen" -t "$_mcf_color" | awk -v key="$_mcf_field" '
      $1 == key {
         hex = $2
         gsub(/^#/, "", hex)
         printf("#%s%s%s\n", substr(hex, 1, 2), substr(hex, 5, 2), substr(hex, 9, 2))
         exit
      }
   '
}

if [ -r "$NSCDE_PALETTE_FILE" ]; then
   _pal_active=$(nscde_palette_color 1 "$NSCDE_PALETTE_FILE")
   _pal_inactive=$(nscde_palette_color 2 "$NSCDE_PALETTE_FILE")
   _pal_transient=$(nscde_palette_color 6 "$NSCDE_PALETTE_FILE")

   # Match NsCDE/FVWM colorset semantics instead of using raw palette slots
   # directly. Colorset 2 (active windows) is derived from palette slot 1,
   # colorset 1 (inactive windows and regular menus) from palette slot 2,
   # and colorset 20/22 supply auxiliary surfaces.
   _active_title_bg=$(_motif_color_field "$_pal_active" bg_color)
   _active_border="$_active_title_bg"
   _active_border_top=$(_motif_color_field "$_pal_active" ts_color)
   _active_border_left="$_active_border_top"
   _active_border_bottom=$(_motif_color_field "$_pal_active" bs_color)
   _active_border_right="$_active_border_bottom"
   _active_text=$(_motif_color_field "$_pal_active" fg_color)

   _inactive_title_bg=$(_motif_color_field "$_pal_inactive" bg_color)
   _inactive_border="$_inactive_title_bg"
   _inactive_border_top=$(_motif_color_field "$_pal_inactive" ts_color)
   _inactive_border_left="$_inactive_border_top"
   _inactive_border_bottom=$(_motif_color_field "$_pal_inactive" bs_color)
   _inactive_border_right="$_inactive_border_bottom"
   _inactive_text=$(_motif_color_field "$_pal_inactive" fg_color)

   _menu_bg="$_inactive_title_bg"
   _menu_text="$_inactive_text"
   _menu_active_bg=$(_motif_color_field "$_pal_inactive" sel_color)
   _menu_active_text="$_inactive_text"
   _menu_border="$_inactive_border_bottom"
   _menu_sep="$_inactive_border_bottom"
   _menu_title_bg="$_active_title_bg"
   _menu_title_text="$_active_text"

   _osd_bg=$(_motif_color_field "$_pal_transient" bg_color)
   _osd_border=$(_motif_color_field "$_pal_transient" bs_color)
   _osd_text=$(_motif_color_field "$_pal_transient" fg_color)

   _active_bevel_highlight="$_active_border_top"
   _active_bevel_shadow="$_active_border_bottom"
   _inactive_bevel_highlight="$_inactive_border_top"
   _inactive_bevel_shadow="$_inactive_border_bottom"

   _button_bg="$_inactive_title_bg"
   _button_highlight="$_inactive_border_top"
   _button_shadow="$_inactive_border_bottom"
   _button_pressed_bg=$(_motif_color_field "$_pal_inactive" sel_color)

   _groove_highlight="$_active_border_top"
   _groove_shadow="$_active_border_bottom"

   _handle_highlight="$_inactive_border_top"
   _handle_shadow="$_inactive_border_bottom"
else
   # Hardcoded CDE-like defaults (Charcoal-inspired)
   _active_border="#6b7785"
   _active_border_top="#8a9baa"
   _active_border_left="#8a9baa"
   _active_border_bottom="#4f5964"
   _active_border_right="#4f5964"
   _inactive_border="#4f5964"
   _inactive_border_top="#6b7785"
   _inactive_border_left="#6b7785"
   _inactive_border_bottom="#3a434b"
   _inactive_border_right="#3a434b"
   _active_title_bg="#355d84"
   _inactive_title_bg="#6b7785"
   _active_text="#ffffff"
   _inactive_text="#e7e7e7"
   _menu_bg="#b7c1ca"
   _menu_text="#101010"
   _menu_active_bg="#355d84"
   _menu_active_text="#ffffff"
   _menu_border="#4f5964"
   _menu_sep="#4f5964"
   _menu_title_bg="#355d84"
   _menu_title_text="#ffffff"
   _osd_bg="#b7c1ca"
   _osd_border="#4f5964"
   _osd_text="#101010"
   _active_bevel_highlight="#8a9baa"
   _active_bevel_shadow="#4f5964"
   _inactive_bevel_highlight="#6b7785"
   _inactive_bevel_shadow="#3a434b"
   # Button bevel (P5)
   _button_bg="#6b7785"
   _button_highlight="#8a9baa"
   _button_shadow="#4f5964"
   _button_pressed_bg="#4f5964"
   # Separator groove (P6)
   _groove_highlight="#8a9baa"
   _groove_shadow="#4f5964"
   # Bottom handle (P4)
   _handle_highlight="#8a9baa"
   _handle_shadow="#4f5964"
fi

function _write_nscde_menu_xpm
{
   _wnmx_dst=$1
   _wnmx_top=$2
   _wnmx_bottom=$3

   cat > "$_wnmx_dst" <<EOF
/* XPM */
static char *menu_xpm[] = {
"12 4 3 1",
"  c None",
"# c $_wnmx_bottom",
". c $_wnmx_top",
"............",
".          #",
".          #",
".###########"
};
EOF
}

function _write_nscde_iconify_xpm
{
   _wnix_dst=$1
   _wnix_top=$2
   _wnix_bottom=$3

   cat > "$_wnix_dst" <<EOF
/* XPM */
static char *iconify_xpm[] = {
"4 4 3 1",
"  c None",
"# c $_wnix_bottom",
". c $_wnix_top",
"...#",
".  #",
".  #",
".###"
};
EOF
}

cat > "$THEME_DIR/themerc" <<EOF
border.width: 5
window.titlebar.padding.width: 0
window.titlebar.padding.height: 0
window.active.border.color: $_active_border
window.active.border.color.top: $_active_border_top
window.active.border.color.left: $_active_border_left
window.active.border.color.bottom: $_active_border_bottom
window.active.border.color.right: $_active_border_right
window.active.frame.outer.width: 1
window.active.frame.inner.width: 4
window.inactive.border.color: $_inactive_border
window.inactive.border.color.top: $_inactive_border_top
window.inactive.border.color.left: $_inactive_border_left
window.inactive.border.color.bottom: $_inactive_border_bottom
window.inactive.border.color.right: $_inactive_border_right
window.inactive.frame.outer.width: 1
window.inactive.frame.inner.width: 4
window.active.titlebar.bevel.highlight.color: $_active_bevel_highlight
window.active.titlebar.bevel.shadow.color: $_active_bevel_shadow
window.active.titlebar.bevel.width: 1
window.inactive.titlebar.bevel.highlight.color: $_inactive_bevel_highlight
window.inactive.titlebar.bevel.shadow.color: $_inactive_bevel_shadow
window.inactive.titlebar.bevel.width: 1
window.button.bg.color: $_button_bg
window.button.bg.highlight.color: $_button_highlight
window.button.bg.shadow.color: $_button_shadow
window.button.pressed.bg.color: $_button_pressed_bg
window.button.pressed.bg.highlight.color: $_button_shadow
window.button.pressed.bg.shadow.color: $_button_highlight
window.separator.groove.width: 1
window.separator.groove.highlight.color: $_groove_highlight
window.separator.groove.shadow.color: $_groove_shadow
window.handle.height: 5
window.handle.bevel.highlight.color: $_handle_highlight
window.handle.bevel.shadow.color: $_handle_shadow
window.active.title.bg.color: $_active_title_bg
window.inactive.title.bg.color: $_inactive_title_bg
window.*.title.bg: Solid
window.active.label.text.color: $_active_text
window.inactive.label.text.color: $_inactive_text
window.label.text.justify: center
window.button.width: 16
window.button.height: 16
window.button.spacing: 0
window.button.hover.bg.color: #ffffff20
window.button.hover.bg.corner-radius: 0
window.active.button.unpressed.image.color: $_active_text
window.inactive.button.unpressed.image.color: $_inactive_text
menu.border.width: 1
menu.border.color: $_menu_border
menu.items.bg.color: $_menu_bg
menu.items.text.color: $_menu_text
menu.items.active.bg.color: $_menu_active_bg
menu.items.active.text.color: $_menu_active_text
menu.items.padding.x: 8
menu.items.padding.y: 4
menu.separator.width: 1
menu.separator.padding.width: 4
menu.separator.padding.height: 3
menu.separator.color: $_menu_sep
menu.title.bg.color: $_menu_title_bg
menu.title.text.color: $_menu_title_text
menu.title.text.justify: Center
osd.bg.color: $_osd_bg
osd.border.color: $_osd_border
osd.border.width: 2
osd.label.text.color: $_osd_text
osd.workspace-switcher.boxes.width: 24
osd.workspace-switcher.boxes.height: 18
osd.workspace-switcher.boxes.border.width: 2
EOF

_write_nscde_menu_xpm "$THEME_DIR/menu-active.xpm" \
   "$_active_bevel_highlight" "$_active_bevel_shadow"
_write_nscde_menu_xpm "$THEME_DIR/menu-inactive.xpm" \
   "$_inactive_bevel_highlight" "$_inactive_bevel_shadow"
_write_nscde_iconify_xpm "$THEME_DIR/iconify-active.xpm" \
   "$_active_bevel_highlight" "$_active_bevel_shadow"
_write_nscde_iconify_xpm "$THEME_DIR/iconify-inactive.xpm" \
   "$_inactive_bevel_highlight" "$_inactive_bevel_shadow"

cat > "$THEME_DIR/close.xbm" <<'EOF'
#define close_width 8
#define close_height 8
static unsigned char close_bits[] = {
  0x81, 0x42, 0x24, 0x18, 0x18, 0x24, 0x42, 0x81 };
EOF

cat > "$THEME_DIR/max.xbm" <<'EOF'
#define max_width 8
#define max_height 8
static unsigned char max_bits[] = {
  0xff, 0x81, 0x81, 0x81, 0x81, 0x81, 0x81, 0xff };
EOF

cat > "$THEME_DIR/max_toggled.xbm" <<'EOF'
#define max_toggled_width 8
#define max_toggled_height 8
static unsigned char max_toggled_bits[] = {
  0x7e, 0x42, 0x5a, 0x5a, 0x42, 0x42, 0x42, 0x7e };
EOF

cat > "$THEME_DIR/iconify.xbm" <<'EOF'
#define iconify_width 8
#define iconify_height 8
static unsigned char iconify_bits[] = {
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xff, 0xff };
EOF

cat > "$THEME_DIR/shade.xbm" <<'EOF'
#define shade_width 8
#define shade_height 8
static unsigned char shade_bits[] = {
  0xff, 0x81, 0xc3, 0xe7, 0xff, 0x00, 0x00, 0x00 };
EOF

cat > "$THEME_DIR/shade_toggled.xbm" <<'EOF'
#define shade_toggled_width 8
#define shade_toggled_height 8
static unsigned char shade_toggled_bits[] = {
  0x00, 0x00, 0x00, 0xff, 0xe7, 0xc3, 0x81, 0xff };
EOF

cat > "$THEME_DIR/desk.xbm" <<'EOF'
#define desk_width 8
#define desk_height 8
static unsigned char desk_bits[] = {
  0x3c, 0x42, 0x81, 0xa5, 0x81, 0x99, 0x42, 0x3c };
EOF

cat > "$THEME_DIR/desk_toggled.xbm" <<'EOF'
#define desk_toggled_width 8
#define desk_toggled_height 8
static unsigned char desk_toggled_bits[] = {
  0x3c, 0x7e, 0xff, 0xdb, 0xff, 0xe7, 0x7e, 0x3c };
EOF

# 2x scale tier (16x16) XBM button glyphs
# Generated by 2x nearest-neighbor scaling from 8x8 masters.
# Used for HiDPI displays at 2x scale factor.

mkdir -p "$THEME_DIR/2x"

cat > "$THEME_DIR/2x/close.xbm" <<'EOF'
#define close_width 16
#define close_height 16
static unsigned char close_bits[] = {
  0x03, 0xc0, 0x03, 0xc0, 0x0c, 0x30, 0x0c, 0x30,
  0x30, 0x0c, 0x30, 0x0c, 0xc0, 0x03, 0xc0, 0x03,
  0xc0, 0x03, 0xc0, 0x03, 0x30, 0x0c, 0x30, 0x0c,
  0x0c, 0x30, 0x0c, 0x30, 0x03, 0xc0, 0x03, 0xc0 };
EOF

cat > "$THEME_DIR/2x/max.xbm" <<'EOF'
#define max_width 16
#define max_height 16
static unsigned char max_bits[] = {
  0xff, 0xff, 0xff, 0xff, 0x03, 0xc0, 0x03, 0xc0,
  0x03, 0xc0, 0x03, 0xc0, 0x03, 0xc0, 0x03, 0xc0,
  0x03, 0xc0, 0x03, 0xc0, 0x03, 0xc0, 0x03, 0xc0,
  0x03, 0xc0, 0x03, 0xc0, 0xff, 0xff, 0xff, 0xff };
EOF

cat > "$THEME_DIR/2x/max_toggled.xbm" <<'EOF'
#define max_toggled_width 16
#define max_toggled_height 16
static unsigned char max_toggled_bits[] = {
  0xfc, 0x3f, 0xfc, 0x3f, 0x0c, 0x30, 0x0c, 0x30,
  0xcc, 0x33, 0xcc, 0x33, 0xcc, 0x33, 0xcc, 0x33,
  0x0c, 0x30, 0x0c, 0x30, 0x0c, 0x30, 0x0c, 0x30,
  0x0c, 0x30, 0x0c, 0x30, 0xfc, 0x3f, 0xfc, 0x3f };
EOF

cat > "$THEME_DIR/2x/iconify.xbm" <<'EOF'
#define iconify_width 16
#define iconify_height 16
static unsigned char iconify_bits[] = {
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff, 0xff };
EOF

cat > "$THEME_DIR/2x/shade.xbm" <<'EOF'
#define shade_width 16
#define shade_height 16
static unsigned char shade_bits[] = {
  0xff, 0xff, 0xff, 0xff, 0x03, 0xc0, 0x03, 0xc0,
  0x0f, 0xf0, 0x0f, 0xf0, 0x3f, 0xfc, 0x3f, 0xfc,
  0xff, 0xff, 0xff, 0xff, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 };
EOF

cat > "$THEME_DIR/2x/shade_toggled.xbm" <<'EOF'
#define shade_toggled_width 16
#define shade_toggled_height 16
static unsigned char shade_toggled_bits[] = {
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0xff, 0xff, 0xff, 0xff,
  0x3f, 0xfc, 0x3f, 0xfc, 0x0f, 0xf0, 0x0f, 0xf0,
  0x03, 0xc0, 0x03, 0xc0, 0xff, 0xff, 0xff, 0xff };
EOF

cat > "$THEME_DIR/2x/desk.xbm" <<'EOF'
#define desk_width 16
#define desk_height 16
static unsigned char desk_bits[] = {
  0xf0, 0x0f, 0xf0, 0x0f, 0x0c, 0x30, 0x0c, 0x30,
  0x03, 0xc0, 0x03, 0xc0, 0x33, 0xcc, 0x33, 0xcc,
  0x03, 0xc0, 0x03, 0xc0, 0xc3, 0xc3, 0xc3, 0xc3,
  0x0c, 0x30, 0x0c, 0x30, 0xf0, 0x0f, 0xf0, 0x0f };
EOF

cat > "$THEME_DIR/2x/desk_toggled.xbm" <<'EOF'
#define desk_toggled_width 16
#define desk_toggled_height 16
static unsigned char desk_toggled_bits[] = {
  0xf0, 0x0f, 0xf0, 0x0f, 0xfc, 0x3f, 0xfc, 0x3f,
  0xff, 0xff, 0xff, 0xff, 0xcf, 0xf3, 0xcf, 0xf3,
  0xff, 0xff, 0xff, 0xff, 0x3f, 0xfc, 0x3f, 0xfc,
  0xfc, 0x3f, 0xfc, 0x3f, 0xf0, 0x0f, 0xf0, 0x0f };
EOF

echo "$THEME_DIR"
